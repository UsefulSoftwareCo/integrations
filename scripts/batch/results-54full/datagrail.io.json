    "summary": "DataGrail exposes two tenant-scoped HTTP APIs (v1 and v2) authenticated with bearer API keys, plus a tenant-scoped MCP server authenticated via OAuth authorization from an MCP client.",
    "description": "DataGrail provides privacy operations software for managing privacy requests, consent, data discovery, risk, and related governance workflows. Its platform is delivered per customer tenant on datagrail.io subdomains.",
    "credentials": {
      "dg_api_key": {
        "type": "api_key",
        "label": "DataGrail API key",
        "generateUrl": "https://docs.datagrail.io/api/v2/authentication/",
        "setup": "Log in to your DataGrail tenant, go to [Authentication](https://docs.datagrail.io/api/v2/authentication/) instructions or directly in the app to **Settings > API Keys**, then select **Create API Key**. Enter a name, choose the needed permissions, create the key, and copy it immediately; DataGrail says the key is not visible after the modal closes. For v1 API access, the docs say to request API access/API keys from your Account Manager or [support@datagrail.io](mailto:support@datagrail.io)."
      },
      "dg_mcp_oauth": {
        "type": "oauth2",
        "label": "DataGrail MCP OAuth connection",
        "generateUrl": "https://docs.datagrail.io/docs/vera/vera-mcp/introduction-and-use",
        "setup": "Have your DataGrail administrator enable external MCP access in **Settings > MCP Tool Access** as described in [Introduction & Setup](https://docs.datagrail.io/docs/vera/vera-mcp/introduction-and-use) and [Controlling Tool Access](https://docs.datagrail.io/docs/vera/vera-mcp/administration). Then connect an MCP client to `https://<your-subdomain>.datagrail.io/api/v2/mcp`; the client opens the DataGrail authorization screen, you sign in with your DataGrail account, review the requested tools, and click **Authorize**. The connection persists until revoked."
      }
    },
