    "summary": "Omni exposes a bearer-token HTTP API, an OAuth- or API-key-authenticated MCP server at callbacks.omniapp.co, and an installable Omni CLI with OAuth or API-token auth.",
    "description": "Omni is a business intelligence and semantic-layer platform for querying data, managing models and content, and powering analytics workflows. It also provides an AI-oriented MCP server so external AI clients can query Omni data and search Omni documentation.",
    "credentials": {
      "omni_api_token": {
        "type": "bearer",
        "label": "Omni API token (Organization API key or Personal Access Token)",
        "generateUrl": "https://docs.omni.co/api/authentication",
        "setup": "Create a token in Omni using the easiest path described in [API authentication](https://docs.omni.co/api/authentication). For an organization-wide key, an Organization Admin goes to **Settings > API access > Organization keys** and clicks **Generate new key**. For a user-scoped PAT, first have an admin enable **Settings > API access > Personal tokens**, then the user opens **Profile > Manage account > Generate token**. Use the resulting token as `Authorization: Bearer <token>`.",
        "acquisition": "manual"
      },
      "omni_oauth_client": {
        "type": "oauth2",
        "label": "Omni OAuth client for MCP/CLI OAuth",
        "generateUrl": "https://omniapp.co/oauth/register",
        "setup": "Register an OAuth client against Omni’s dynamic client registration endpoint at [registration endpoint](https://omniapp.co/oauth/register). Omni publishes its authorization server metadata at [oauth-authorization-server](https://omniapp.co/.well-known/oauth-authorization-server): use `authorization_code` with PKCE `S256`, scope `mcp:access`, and note that `token_endpoint_auth_methods_supported` is `none` (public client). For MCP clients, use the protected resource metadata discovered from the server; Omni’s auth docs describe this browser-based OAuth flow in [MCP authentication](https://docs.omni.co/ai/mcp/authentication).",
        "acquisition": "manual"
      }
