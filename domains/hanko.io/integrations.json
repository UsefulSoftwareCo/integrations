{
  "domain": "hanko.io",
  "summary": "Hanko exposes public HTTP APIs (Public API, Flow API, JWKS) plus a protected Admin API; auth is via Hanko API key (Bearer header) for Admin, while Public/Flow/JWKS are public or session-JWT based.",
  "surfaces": [
    {
      "authStatus": "required",
      "name": "Hanko Public API",
      "slug": "hanko-public-api",
      "type": "http",
      "url": "https://{tenant_id}.hanko.io"
    },
    {
      "authStatus": "none",
      "name": "Hanko Flow API",
      "slug": "hanko-flow-api",
      "type": "http",
      "url": "https://{tenant_id}.hanko.io"
    },
    {
      "authStatus": "none",
      "name": "Hanko JWKS",
      "slug": "hanko-jwks",
      "type": "http",
      "url": "https://{tenant_id}.hanko.io/.well-known/jwks.json"
    }
  ]
}
