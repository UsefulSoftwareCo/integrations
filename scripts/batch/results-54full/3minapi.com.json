        "type": "oauth2",
        "label": "3Min API account OAuth",
        "generateUrl": "https://3minapi.com/api/mcp/oauth/register",
        "setup": "For MCP clients that use OAuth, start connection from the client against the 3Min API MCP server at `https://3minapi.com/api/mcp`. The service exposes OAuth endpoints at `https://3minapi.com/api/mcp/oauth/authorize` and `https://3minapi.com/api/mcp/oauth/token`, plus dynamic client registration at `https://3minapi.com/api/mcp/oauth/register`. ChatGPT and Claude sign in with your 3Min API account instead of using an API key.",
        "acquisition": "manual"
      }
