    "summary": "ucsb.edu exposes a developer portal for a REST API gateway at `https://api.ucsb.edu`, with OpenAPI-described APIs that use a UCSB app Consumer Key on every request and, for some endpoints, additional Campus LDAP Basic auth and/or a Google-issued end-user JWT.",
    "description": "The University of California, Santa Barbara provides campus data and operational APIs for academic, student, dining, housing, employee, and administrative systems through its API developer portal. These APIs are intended for approved campus applications and departments, with different access levels depending on the dataset.",
    "credentials": {
      "ucsb_consumer_key": {
        "type": "api_key",
        "label": "UCSB API Consumer Key",
        "generateUrl": "https://developer.ucsb.edu/docs/creating-your-first-app",
        "setup": "Create a developer-portal account at [UCSB API Developer Portal](https://developer.ucsb.edu/user/register), then sign in and follow [Creating Your First App](https://developer.ucsb.edu/docs/creating-your-first-app). Create an app, select the APIs it will use, and open the app's **Keys** section to copy the **Consumer Key**. This is the API key you send as the `ucsb-api-key` header. The key only works for APIs on that app that are in **Approved** status; some APIs are auto-approved and others require a separate access approval process.",
        "acquisition": "manual"
      },
      "ucsb_ldap_basic": {
        "type": "basic",
        "label": "Campus LDAP application or functional account",
        "generateUrl": "https://etsc.ucsb.edu",
        "setup": "Request a Campus LDAP account using the process on [Campus LDAP Accounts (Application vs Functional)](https://developer.ucsb.edu/docs/accounts/ldap-accounts). Sign in to [ETSC](https://etsc.ucsb.edu), go to **Advanced Technical Services > Identity and Access**, then choose **Create UCSBNetID Functional Account** and submit the requested description for either an application account (`ou=Applications`) or a functional account (`ou=People`). Use the issued UCSBNetID and password as HTTP Basic credentials for APIs that require backend application identity.",
        "acquisition": "manual"
      },
      "ucsb_google_user_jwt": {
        "type": "jwt",
        "label": "Google OAuth end-user JWT for a UCSB Google account",
        "generateUrl": "https://console.developers.google.com/",
        "setup": "For APIs that require end-user identity, create Google OAuth credentials using a UCSB Google account (`ucsbNetId@ucsb.edu`) as described in [Security - Google End User OAuth](https://developer.ucsb.edu/docs/security/google-end-user-oauth), then follow Google's [OAuth 2.0 documentation](https://developers.google.com/identity/protocols/OAuth2) to obtain a user JWT/ID token for the signed-in end user. UCSB's docs say this token is sent to the API in the `ucsb-user-jwt` header.",
        "acquisition": "manual"
      }
