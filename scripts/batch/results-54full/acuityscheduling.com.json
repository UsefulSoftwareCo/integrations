    "summary": "Acuity Scheduling exposes one public developer integration surface on acuityscheduling.com: a REST HTTP Scheduling API at `https://acuityscheduling.com/api/v1`, authenticated either by HTTP Basic with Acuity-issued User ID + API Key or by OAuth2 bearer tokens from a registered Acuity OAuth app.",
    "description": "Acuity Scheduling is an online appointment booking and scheduling service. Businesses use it to publish booking pages, manage calendars, and handle appointment-related workflows.",
    "credentials": {
      "acuity_basic": {
        "type": "basic",
        "label": "Acuity API credentials (User ID + API Key)",
        "generateUrl": "https://secure.acuityscheduling.com/app.php?action=settings&key=api",
        "setup": "In Acuity, open **Integrations** and use **view credentials** in the API section, or go directly to [API credentials](https://secure.acuityscheduling.com/app.php?action=settings&key=api). Copy your numeric `User ID` and `API Key`. The help article [Using custom CSS, webhooks, and APIs](https://help.acuityscheduling.com/hc/en-us/articles/16676949253389-Using-custom-CSS-webhooks-and-APIs) notes API access is available on the Premium or Powerhouse plan."
      },
      "acuity_oauth_app": {
        "type": "oauth2",
        "label": "Acuity OAuth2 client",
        "generateUrl": "https://acuityscheduling.com/oauth2/register",
        "setup": "Register an OAuth app at [OAuth2 Account Registration](https://acuityscheduling.com/oauth2/register). Provide the app name, email, website, description, and callback URIs. Then use the OAuth2 flow documented in [OAuth2](https://developers.acuityscheduling.com/docs/oauth2): send users to `https://acuityscheduling.com/oauth2/authorize` with scope `api-v1`, exchange the returned code at `https://acuityscheduling.com/oauth2/token`, and use the resulting bearer access token for API calls."
      }
