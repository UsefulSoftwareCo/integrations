    "summary": "Airbyte exposes two authenticated HTTP APIs (the Platform API and Airbyte Agents API), one authenticated hosted MCP server, and two CLIs (`airbyte-agent` and `abctl`).",
    "description": "Airbyte provides data integration and replication software, including a hosted Airbyte Agents product for AI agents and a platform for moving data between sources and destinations. It is available as a cloud service and as self-managed deployments.",
    "credentials": {
      "airbyte_app": {
        "type": "app",
        "label": "Airbyte application client credentials (client ID + client secret)",
        "generateUrl": "https://docs.airbyte.com/platform/using-airbyte/configuring-api-access",
        "setup": "For Airbyte Platform API access, open Airbyte and go to **User settings** → **Applications** to create an application and reveal its `client_id` and `client_secret`. On Airbyte Cloud or Self-Managed Enterprise, click **Create an application**; on Airbyte Core, an application is already provided. See [Get an API access token](https://docs.airbyte.com/platform/using-airbyte/configuring-api-access). You exchange these credentials for a short-lived bearer token at `https://api.airbyte.com/v1/applications/token` for Cloud, or `<YOUR_AIRBYTE_URL>/api/public/v1/applications/token` for self-managed."
      },
      "airbyte_agents_client": {
        "type": "app",
        "label": "Airbyte Agents client credentials (AIRBYTE_CLIENT_ID + AIRBYTE_CLIENT_SECRET)",
        "generateUrl": "https://app.airbyte.ai",
        "setup": "Sign in to [Airbyte Agents](https://app.airbyte.ai) and copy `AIRBYTE_CLIENT_ID` and `AIRBYTE_CLIENT_SECRET` from the Profile page, as described in [API authentication](https://docs.airbyte.com/ai-agents/interfaces/api/authentication/). Exchange them for a short-lived application token by POSTing to `https://api.airbyte.ai/api/v1/account/applications/token`. The SDK can read them from environment variables `AIRBYTE_CLIENT_ID` and `AIRBYTE_CLIENT_SECRET` and manage token refresh automatically."
      },
      "airbyte_agents_cli_login": {
        "type": "oauth2",
        "label": "Airbyte Agents CLI login session",
        "generateUrl": "https://app.airbyte.ai",
        "setup": "Install the CLI, then run `airbyte-agent login` to open a browser sign-in flow against Airbyte Agents and store the CLI's credentials in `$HOME/.airbyte-agent/settings.json` with `0600` permissions. On headless machines, use `airbyte-agent login --manual`. See [CLI](https://docs.airbyte.com/ai-agents/interfaces/cli/) and [CLI authentication](https://docs.airbyte.com/ai-agents/interfaces/cli/authenticate)."
      }
    },
