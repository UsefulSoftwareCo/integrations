        "setup": "For heavier or advanced Scite API usage, contact Scite at [hi@scite.ai](mailto:hi@scite.ai) or [sales@scite.ai](mailto:sales@scite.ai) to obtain an API token. Send it as `Authorization: Bearer <token>`.",
        "acquisition": "manual"
      },
      "scite_mcp_oauth": {
        "type": "oauth2",
        "label": "Scite MCP OAuth client/account access",
        "generateUrl": "https://api.scite.ai/.well-known/oauth-authorization-server",
        "setup": "Use an MCP client that supports OAuth 2.1 with PKCE and dynamic client registration against [Scite's OAuth metadata](https://api.scite.ai/.well-known/oauth-authorization-server). A Scite subscription is required for MCP access per [Scite MCP setup](https://scite.ai/mcp). Most clients discover the authorization server automatically; if configuring manually, use `https://api.scite.ai/mcp/oauth/authorize` for authorization, `https://api.scite.ai/mcp/oauth/token` for tokens, register via `https://api.scite.ai/mcp/oauth/register`, and request scope `mcp`.",
        "acquisition": "manual"
      },
      "scite_mcp_client_credentials": {
        "type": "compound",
        "label": "Scite MCP API key pair (client_id + client_secret)",
        "generateUrl": "https://api.scite.ai/openapi.json",
        "setup": "For programmatic MCP access, contact Scite at [sales@scite.ai](mailto:sales@scite.ai) to obtain `client_id` and `client_secret`. Exchange them at `POST https://api.scite.ai/auth_token_users/token` with JSON body containing `client_id`, `client_secret`, and `grant_type`=`client_credentials`, then use the returned bearer token in `Authorization: Bearer <access_token>` when calling the MCP endpoint.",
        "acquisition": "manual"
      }
