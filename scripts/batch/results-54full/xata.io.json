    "summary": "Xata exposes a control-plane HTTP API at `https://api.xata.tech`, a separate branch-scoped SQL gateway HTTP API at `https://{branch}.{region}.xata.tech`, and the `xata` CLI; all require authentication.",
    "description": "Xata is a managed PostgreSQL platform focused on instant branching, production-like development environments, and data anonymization. It lets teams create and manage isolated Postgres branches, projects, and organizations for development, testing, and production workflows.",
    "credentials": {
      "xata_bearer": {
        "type": "bearer",
        "label": "Xata API key or OAuth access token for the control-plane API",
        "generateUrl": "https://xata.io/docs/platform/api-key",
        "setup": "Create a Xata account in [console.xata.io](https://console.xata.io), then create a user or organization API key using the steps in [API Keys](https://xata.io/docs/platform/api-key) or the CLI commands in [keys](https://xata.io/docs/cli/keys) such as `xata keys user create` or `xata keys organization create`. The API reference also shows the control-plane API accepts `Authorization: Bearer <token>`, and the CLI can print a current access token with `xata auth access-token` after `xata auth login`.",
        "acquisition": "manual"
      },
      "xata_branch_connstr": {
        "type": "compound",
        "label": "Branch PostgreSQL connection string",
        "generateUrl": "https://xata.io/docs/platform/branch",
        "setup": "Get the branch connection string from the branch overview in the Xata console as described in [Branches](https://xata.io/docs/platform/branch) under **Connect**, or retrieve branch details/credentials via the control-plane API documented in [Get branch details](https://xata.io/docs/api-reference/branches/get-branch-details.md) and related branch credential endpoints listed in [docs index](https://xata.io/docs/docs/llms.txt). This credential is a full PostgreSQL URI like `postgres://user:pass@{branch}.{region}.xata.tech/db` and is sent as the `Connection-String` header to the SQL gateway.",
        "acquisition": "manual"
      },
      "xata_cli_login": {
        "type": "oauth2",
        "label": "Xata CLI login profile",
        "generateUrl": "https://xata.io/docs/cli/auth",
        "setup": "Install the CLI from [CLI Reference](https://xata.io/docs/cli), then run `xata auth login` as documented in [auth](https://xata.io/docs/cli/auth). This creates a local authenticated CLI profile; `xata auth access-token` can print the active access token and `xata auth switch` can change profiles.",
        "acquisition": "manual"
      }
    },
