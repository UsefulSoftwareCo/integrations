{
  "domain": "agilitycms.com",
  "summary": "Agility CMS exposes REST Content Fetch, REST Content Management, GraphQL, MCP, and CLI surfaces; auth uses API keys for read APIs, PATs for management/MCP, and CLI login for the Agility CLI.",
  "surfaces": [
    {
      "authStatus": "required",
      "name": "Agility CMS Content Fetch API",
      "slug": "agility-cms-content-fetch-api",
      "type": "http",
      "url": "https://api.aglty.io/{instance-guid}/fetch"
    },
    {
      "authStatus": "required",
      "name": "Agility CMS Content Management API",
      "slug": "agility-cms-content-management-api",
      "type": "http",
      "url": "https://mgmt.aglty.io/api/v1/instance/{guid}"
    },
    {
      "authStatus": "required",
      "name": "Agility CMS GraphQL API",
      "slug": "agility-cms-graphql-api",
      "type": "graphql",
      "url": "https://api.aglty.io/{instance-guid}/{apitype}/graphql"
    },
    {
      "authStatus": "required",
      "name": "Agility CMS MCP Server",
      "slug": "agility-cms-mcp-server",
      "type": "mcp",
      "url": "https://mcp.agilitycms.com/api/mcp"
    },
    {
      "authStatus": "required",
      "command": "agility",
      "name": "Agility CLI",
      "slug": "agility-cli",
      "type": "cli"
    }
  ]
}
