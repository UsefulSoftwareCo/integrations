    "summary": "Sentry exposes a REST Web API, an OAuth-protected MCP server at `https://mcp.sentry.dev/mcp`, and the `sentry-cli` command-line tool; authentication is via Sentry-issued bearer tokens or OAuth app credentials depending on the surface.",
    "description": "Sentry is an application monitoring and observability platform for tracking errors, performance, releases, logs, and related software health data. Teams use it to inspect issues and operational signals from their applications.",
    "credentials": {
      "sentry_org_token": {
        "type": "bearer",
        "label": "Sentry organization auth token",
        "generateUrl": "https://sentry.io/orgredirect/organizations/:orgslug/settings/auth-tokens/",
        "setup": "In [Sentry Auth Tokens](https://docs.sentry.io/account/auth-tokens/), create an **Organization Token** from **Settings → Developer Settings → Organization Tokens** (or open the org token page directly at [Organization Tokens](https://sentry.io/orgredirect/organizations/:orgslug/settings/auth-tokens/)). These tokens are intended for CI and `sentry-cli`, are shown only once when created, and are sent as `Authorization: Bearer <token>` to the API or via `SENTRY_AUTH_TOKEN` / `~/.sentryclirc` for the CLI."
      },
      "sentry_personal_token": {
        "type": "bearer",
        "label": "Sentry personal auth token",
        "generateUrl": "https://sentry.io/settings/account/api/auth-tokens/",
        "setup": "Create a **Personal Token** in Sentry user settings under **User settings → Personal Tokens** as described in [Auth Tokens](https://docs.sentry.io/account/auth-tokens/) and [API Authentication](https://docs.sentry.io/api/auth/). Choose the scopes you need; personal token scopes cannot be edited later. Use the token as `Authorization: Bearer <token>`."
      },
      "sentry_internal_integration_token": {
        "type": "bearer",
        "label": "Sentry internal integration token",
        "generateUrl": "https://sentry.io/settings/developer-settings/",
        "setup": "In [Integration Platform](https://docs.sentry.io/integrations/integration-platform/), go to **Settings → Developer Settings** and create an **Internal Integration** for your organization. Configure the required scopes/permissions, then use the issued token with the Sentry API as `Authorization: Bearer <token>`. Internal integrations are recommended when organization tokens do not grant enough API access."
      },
      "sentry_oauth_app": {
        "type": "oauth2",
        "label": "Sentry OAuth application credentials",
        "generateUrl": "https://sentry.io/settings/developer-settings/",
        "setup": "In [Integration Platform](https://docs.sentry.io/integrations/integration-platform/), go to **Settings → Developer Settings** and create a **Public Integration** to obtain a `client_id` and `client_secret`. Send users to `https://sentry.io/oauth/authorize/`, exchange the code at `https://sentry.io/oauth/token/`, and then call Sentry with the returned bearer access token. Available scopes are documented in [API Authentication](https://docs.sentry.io/api/auth/) and the API permissions docs."
      }
    },
