      },
      "spinify_mcp_oauth": {
        "type": "oauth2",
        "label": "Spinify MCP OAuth client/session",
        "generateUrl": "https://mcp.spinify.com/.well-known/oauth-authorization-server",
        "setup": "Use an MCP client that supports OAuth 2.0 against Spinify's authorization server discovered from [the OAuth authorization server metadata](https://mcp.spinify.com/.well-known/oauth-authorization-server). The metadata advertises `authorization_code` and `refresh_token` grants, PKCE `S256`, `authorization_endpoint` `https://mcp.spinify.com/authorize`, `token_endpoint` `https://mcp.spinify.com/token`, and dynamic client registration at `https://mcp.spinify.com/register`. Supported token endpoint auth methods are `none` and `client_secret_post`, so the easiest path is a public OAuth client using PKCE in an MCP client that can sign in to Spinify.",
        "acquisition": "manual"
      }
    },
