{
  "domain": "qstash.dev",
  "summary": "qstash.dev exposes one authenticated HTTP REST API (QStash), one authenticated MCP server via Upstash credentials, and a public QStash CLI for local development.",
  "surfaces": [
    {
      "authStatus": "required",
      "name": "QStash REST API",
      "slug": "qstash-rest-api",
      "type": "http",
      "url": "https://qstash.upstash.io/v2"
    },
    {
      "authStatus": "required",
      "name": "Upstash MCP Server",
      "slug": "upstash-mcp-server",
      "type": "mcp",
      "url": "stdio://npx -y @upstash/mcp-server@latest --email YOUR_EMAIL --api-key YOUR_API_KEY"
    },
    {
      "authStatus": "none",
      "command": "qstash",
      "name": "QStash CLI",
      "slug": "qstash-cli",
      "type": "cli"
    }
  ]
}
