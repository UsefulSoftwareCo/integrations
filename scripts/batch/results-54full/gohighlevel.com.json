    "summary": "HighLevel exposes a REST API at services.leadconnectorhq.com, an HTTP MCP server at services.leadconnectorhq.com/mcp/, and official Node/Python/PHP SDK packages; auth is via Private Integration Tokens or OAuth 2.0 app-based access tokens, with MCP documented for PIT auth.",
    "description": "HighLevel is a CRM and marketing automation platform with features for contacts, conversations, calendars, payments, workflows, and marketplace apps. Its developer platform lets agencies and sub-accounts build custom integrations and AI-connected workflows against HighLevel data.",
    "credentials": {
      "pit": {
        "type": "bearer",
        "label": "Private Integration Token",
        "generateUrl": "https://marketplace.gohighlevel.com/docs/Authorization/PrivateIntegrationsToken",
        "setup": "In HighLevel, go to `Settings > Private Integrations` in the agency or sub-account/location you want to access, click **Create New Integration**, choose scopes, and copy the generated token. The docs describe this in [Private Integrations](https://marketplace.gohighlevel.com/docs/Authorization/PrivateIntegrationsToken) and the MCP quickstart in [MCP Server](https://marketplace.gohighlevel.com/docs/other/mcp). Send it as `Authorization: Bearer <token>`.",
        "acquisition": "manual"
      },
      "oauth_app": {
        "type": "oauth2",
        "label": "Marketplace OAuth app client credentials",
        "generateUrl": "https://marketplace.gohighlevel.com/",
        "setup": "Create a developer account in the [HighLevel Marketplace](https://marketplace.gohighlevel.com/), go to **My Apps** and **Create App**, then open **Advanced Settings > Auth** to configure scopes, redirect URLs, and obtain the app's client credentials as described in [OAuth 2.0](https://marketplace.gohighlevel.com/docs/Authorization/OAuth2.0). Use those client credentials to run the OAuth 2.0 authorization code flow and obtain access tokens for API calls.",
        "acquisition": "manual"
      }
