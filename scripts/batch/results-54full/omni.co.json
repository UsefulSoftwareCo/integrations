    "summary": "Omni exposes a tenant-scoped REST API, an HTTP MCP server, and an open-source `omni` CLI; all require authentication via Omni-issued tokens or OAuth.",
    "description": "Omni is a business intelligence and analytics platform for modeling data, querying it through a semantic layer, and building content like dashboards and workbooks. It also provides AI-assisted querying and agent integrations over that data.",
    "credentials": {
      "omni_org_api_key": {
        "type": "api_key",
        "label": "Organization API key",
        "generateUrl": "https://docs.omni.co/api/authentication#create",
        "setup": "An Organization Admin can create this in Omni at [API authentication](https://docs.omni.co/api/authentication#create): go to **Settings > API access > Organization keys**, click **Generate new key**, enter a descriptive name, click **Generate**, and copy the key when shown. The secret is only displayed once.",
        "acquisition": "manual"
      },
      "omni_pat": {
        "type": "bearer",
        "label": "Personal Access Token (PAT)",
        "generateUrl": "https://docs.omni.co/api/authentication#create",
        "setup": "First have an Organization Admin enable personal tokens in [API authentication](https://docs.omni.co/api/authentication#create) under **Settings > API access > Personal tokens**. Then a user with **Restricted Querier** or higher can open their profile and choose **Manage account > Generate token** to mint a PAT.",
        "acquisition": "manual"
      },
      "omni_cli_oauth": {
        "type": "oauth2",
        "label": "CLI OAuth login",
        "generateUrl": "https://docs.omni.co/developers/cli/authentication#authenticating-with-oauth",
        "setup": "Install the CLI per [Installing the Omni CLI](https://docs.omni.co/developers/cli/install), then run `omni config login`. Your browser opens to your Omni organization's authorization page; approve the verified Omni CLI app. Omni creates a CLI OAuth PAT for your user and the CLI stores and refreshes the tokens automatically.",
        "acquisition": "manual"
      },
      "omni_mcp_oauth": {
        "type": "oauth2",
        "label": "MCP OAuth authorization",
        "generateUrl": "https://docs.omni.co/ai/mcp/authentication#oauth-authentication",
        "setup": "Ensure your org has the MCP server AI setting enabled in [MCP authentication](https://docs.omni.co/ai/mcp/authentication#requirements) and that personal tokens are enabled. Add your Omni MCP connection URL to an MCP client, start the OAuth flow, then approve the authorization page for your Omni organization. Omni creates an MCP OAuth PAT for your user account automatically.",
        "acquisition": "manual"
      }
    },
