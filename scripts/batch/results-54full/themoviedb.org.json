      "tmdb_api_key": {
        "type": "api_key",
        "label": "TMDB v3 API key",
        "generateUrl": "https://www.themoviedb.org/settings/api",
        "setup": "Sign in to your TMDB account, open the [API settings](https://www.themoviedb.org/settings/api) from your account settings, and apply for an API key. TMDB says you must agree to the terms of use before a key is issued. Use the key on v3 requests as the `api_key` query parameter.",
        "acquisition": "manual"
      },
      "tmdb_read_access_token": {
        "type": "bearer",
        "label": "TMDB API Read Access Token",
        "generateUrl": "https://www.themoviedb.org/settings/api",
        "setup": "Sign in to your TMDB account and open [API settings](https://www.themoviedb.org/settings/api). Under the API section, TMDB provides an `API Read Access Token`. Send it as `Authorization: Bearer <token>`. TMDB documents this as the default authentication method and says it works across both v3 and v4 methods.",
        "acquisition": "manual"
      },
      "tmdb_session_id": {
        "type": "compound",
        "label": "TMDB user session ID",
        "generateUrl": "https://developer.themoviedb.org/reference/authentication-how-do-i-generate-a-session-id",
        "setup": "Create a TMDB user session by following the documented flow at [How do I generate a session id?](https://developer.themoviedb.org/reference/authentication-how-do-i-generate-a-session-id): first create a request token, have the user approve it, then exchange it for a `session_id` with the [Create Session](https://developer.themoviedb.org/reference/authentication-create-session) endpoint. Use the resulting `session_id` as a query parameter on user-authenticated v3 endpoints.",
        "acquisition": "manual"
      },
      "tmdb_guest_session_id": {
        "type": "compound",
        "label": "TMDB guest session ID",
