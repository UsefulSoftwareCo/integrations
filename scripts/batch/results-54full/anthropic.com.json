    "summary": "Anthropic exposes two HTTP integration surfaces at api.anthropic.com (the Claude API and separate Admin APIs), plus two official CLIs (`claude` and `ant`); auth uses Anthropic-issued API keys, Admin API keys, or WIF bearer tokens.",
    "credentials": {
      "anthropic_api_key": {
        "type": "api_key",
        "label": "Anthropic API key",
        "generateUrl": "https://platform.claude.com/settings/keys",
        "setup": "In [Claude Console](https://platform.claude.com/), go to [Settings → API keys](https://platform.claude.com/settings/keys) and create a key. Anthropic says API keys are long-lived `sk-ant-api...` secrets. You can scope usage with [workspaces](https://platform.claude.com/settings/workspaces).",
        "acquisition": "manual"
      },
      "anthropic_wif_token": {
        "type": "bearer",
        "label": "Anthropic Workload Identity Federation access token",
        "generateUrl": "https://platform.claude.com/",
        "setup": "Configure Workload Identity Federation in [Claude Console](https://platform.claude.com/) by creating the resources Anthropic documents for WIF (service account, federation issuer, and federation rule), following [Authentication](https://docs.anthropic.com/docs/en/manage-claude/authentication) and [Workload Identity Federation](https://docs.anthropic.com/docs/en/manage-claude/workload-identity-federation). Your workload then exchanges its IdP-issued JWT at `POST /v1/oauth/token` for a short-lived Anthropic access token, which the SDK can refresh automatically.",
        "acquisition": "manual"
      },
      "anthropic_admin_key": {
        "type": "api_key",
        "label": "Anthropic Admin API key",
        "generateUrl": "https://platform.claude.com/settings/admin-keys",
        "setup": "For a Claude Console organization, sign in as an org admin and create a key at [Claude Console → Settings → Admin keys](https://platform.claude.com/settings/admin-keys). Anthropic documents this key prefix as `sk-ant-admin01-...`. For Claude Enterprise organizations, the primary owner instead creates the organization API key at [claude.ai → Organization settings → API](https://claude.ai/admin-settings/api-access); Anthropic documents that variant as `sk-ant-api01-...` and scope-selected at creation. See [Create an Admin API key](https://docs.anthropic.com/docs/en/manage-claude/admin-api-keys).",
        "acquisition": "manual"
      }
    },
