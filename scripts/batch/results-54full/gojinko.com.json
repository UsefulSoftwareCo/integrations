    "summary": "Jinko exposes a REST API at `api.gojinko.com`, a remote MCP server, and an npm-distributed `jinko` CLI; docs describe API-key auth everywhere plus OAuth for MCP clients and the CLI, and the catalog also lists a public MCP endpoint at `https://mcp.gojinko.com`.",
    "description": "Jinko provides travel infrastructure for AI agents and applications, letting them discover, price, book, and manage flights and hotels. Its platform centers on a shared trip model across MCP, HTTP API, and CLI interfaces.",
    "credentials": {
      "jinko_api_key": {
        "type": "api_key",
        "label": "Jinko API key (`jnk_*`)",
        "generateUrl": "https://gojinko.com/dashboard/keys",
        "setup": "Sign in at [Jinko dashboard keys](https://gojinko.com/dashboard/keys), click **Create key**, give it a name, and copy the `jnk_` key when shown. Sandbox uses separate keys from production; generate the sandbox key from the same dashboard while targeting the sandbox environment documented in [API keys](https://docs.gojinko.com/authentication/api-keys)."
      },
      "jinko_cli_oauth": {
        "type": "oauth2",
        "label": "Jinko CLI OAuth token (device flow)",
        "generateUrl": "https://auth.gojinko.com/device",
        "setup": "Install the CLI from [Connect via CLI](https://docs.gojinko.com/connect/cli), then run `jinko auth login` and choose the OAuth browser sign-in path. The CLI prints a device URL and code; open the URL, approve access, and the CLI stores and refreshes the resulting token in `~/.jinko/config.yaml`. This token works for the CLI and REST `/v1` bearer auth, but the docs say it cannot be reused as a bearer token on the MCP endpoint.",
        "acquisition": "manual"
      },
      "jinko_mcp_oauth": {
        "type": "oauth2",
        "label": "Jinko MCP OAuth via Dynamic Client Registration",
        "setup": "Use an MCP client that supports OAuth with Dynamic Client Registration, then connect it to `https://mcp.builders.gojinko.com/mcp` as shown in [MCP](https://docs.gojinko.com/connect/mcp) or [How to Connect](https://docs.gojinko.com/quickstart). The client discovers `/.well-known/oauth-authorization-server`, dynamically registers itself, and opens the browser-based sign-in flow at Jinko Auth; no manual client registration step is required.",
        "acquisition": "manual"
      }
    },
