        "label": "Canva Connect OAuth client",
        "generateUrl": "https://www.canva.com/developers/integrations",
        "setup": "Create an integration in the [Canva Developer Portal](https://www.canva.com/developers/) and open [Your integrations](https://www.canva.com/developers/integrations). In the integration settings, copy the `Client ID`, click `Generate secret` to mint and save the `Client secret`, and add at least one authorized redirect URL. Canva Connect uses OAuth 2.0 Authorization Code flow with PKCE, so your app also generates its own `code_verifier`/`code_challenge` pair when starting authorization.",
        "acquisition": "manual"
      },
