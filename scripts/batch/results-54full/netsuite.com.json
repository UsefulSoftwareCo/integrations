    "summary": "NetSuite exposes an account-scoped SuiteTalk REST API, an account-scoped MCP server for the NetSuite AI Connector Service, and the SuiteCloud CLI for Node.js; REST supports OAuth 2.0 and token-based auth, while MCP and the CLI use OAuth-based account connections.",
    "description": "NetSuite is Oracle’s cloud ERP and business management platform for finance, operations, commerce, and related business workflows. It lets customers manage NetSuite account data and customizations through web services, development tooling, and AI connector capabilities.",
    "credentials": {
      "netsuite_oauth2_app": {
        "type": "oauth2",
        "label": "NetSuite OAuth 2.0 integration record (client credentials/client secret or public client)",
        "generateUrl": "https://docs.oracle.com/en/cloud/saas/netsuite/ns-online-help/section_157771733782.html",
        "setup": "Create an integration record in NetSuite at [Create Integration Records for Applications to Use OAuth 2.0](https://docs.oracle.com/en/cloud/saas/netsuite/ns-online-help/section_157771733782.html): go to `Setup > Integration > Manage Integrations > New`, enable `Authorization Code Grant` and/or `Client Credentials (Machine to Machine) Grant`, and check the product scopes you need such as `REST Web Services` or `NetSuite AI Connector Service`. Save the record to obtain the OAuth client details; for public-client flows, configure the allowed redirect URI as described in the same guide."
      },
      "netsuite_tba": {
        "type": "compound",
        "label": "NetSuite Token-Based Authentication (consumer key/secret + token ID/secret)",
        "generateUrl": "https://docs.oracle.com/en/cloud/saas/netsuite/ns-online-help/chapter_4247329078.html",
        "setup": "Set up Token-Based Authentication using the NetSuite tutorial at [Token-Based Authentication (TBA)](https://docs.oracle.com/en/cloud/saas/netsuite/ns-online-help/chapter_4247329078.html). In NetSuite, create an integration record to get the consumer key and secret, then issue an access token for a user/role to get the token ID and token secret. Use these values to sign OAuth 1.0 `Authorization` headers for supported SuiteTalk and RESTlet calls."
      },
      "suitecloud_cli_account": {
        "type": "oauth2",
        "label": "SuiteCloud CLI account connection",
        "generateUrl": "https://docs.oracle.com/en/cloud/saas/netsuite/ns-online-help/section_155930842837.html",
        "setup": "Install the CLI from [Installing SuiteCloud CLI for Node.js](https://docs.oracle.com/en/cloud/saas/netsuite/ns-online-help/section_155929845760.html), then in a project folder run `suitecloud account:setup` as described in [Setting Up SuiteCloud CLI for Node.js](https://docs.oracle.com/en/cloud/saas/netsuite/ns-online-help/section_155930842837.html). The CLI walks you through linking your NetSuite account and stores the account connection for later commands."
      }
    },
