    "summary": "Unit exposes a documented REST API for its financial platform plus published white-label UI SDK/package integrations; authentication is via bearer org API tokens or customer API tokens depending on the surface and scope.",
    "description": "Unit is a financial infrastructure platform that lets software companies embed accounts, payments, cards, and capital products into their own products. It offers both a custom API-based integration path and managed ready-to-launch banking experiences.",
    "credentials": {
      "org_api_token": {
        "type": "bearer",
        "label": "Org API token",
        "generateUrl": "https://app.s.unit.sh/signup",
        "setup": "Sign up for a Unit sandbox account at [Sandbox](https://app.s.unit.sh/signup) and choose **Custom Build**. In the Unit Dashboard, go to `Developer → API Tokens` to create an org-level token with the scopes you need; the docs say org API tokens can also be created programmatically or through the Dashboard. Use the live dashboard at [app.unit.co](https://app.unit.co) for production tokens after your live environment is enabled.",
        "acquisition": "manual"
      },
      "customer_token": {
        "type": "bearer",
        "label": "Customer API token",
        "generateUrl": "https://www.unit.co/docs/api/customer-api-tokens/",
        "setup": "First create or identify a Unit customer in your program. Then use an org token with the `customer-token-write` scope to call the Customer Token API described at [Customer API Tokens](https://www.unit.co/docs/api/customer-api-tokens/). For sensitive scopes, first create a verification challenge at `POST /customers/:customerId/token/verification`, collect the OTP from the customer, then create the customer token at `POST /customers/:customerId/token` with `verificationToken` and `verificationCode`. In sandbox, the docs say to use passcode `000001` for this verification flow.",
        "acquisition": "manual"
      }
