    "summary": "conjur.org exposes a self-hosted Conjur REST API and a Conjur CLI; both use Conjur-issued credentials (password, API key, and short-lived access token), with no evidence of GraphQL or MCP surfaces.",
    "description": "Conjur is CyberArk's secrets management and machine identity system for applications and infrastructure. It stores and controls access to secrets and related policy in self-hosted Conjur deployments.",
    "credentials": {
      "conjur_user_password": {
        "type": "basic",
        "label": "Conjur user password",
        "setup": "Use a Conjur user account in your own Conjur deployment. The REST `login` endpoint accepts the Conjur username and password over HTTP Basic auth and returns that user's API key. The docs show `GET /authn/{account}/login` and a `curl --user alice:... https://eval.conjur.org/authn/myorg/login` example in [Login](https://docs.cyberark.com/secrets-manager-sh/12.4/en/content/developer/conjur_api_login.htm).",
        "acquisition": "manual"
      },
      "conjur_api_key": {
        "type": "api_key",
        "label": "Conjur API key",
        "setup": "Mint or retrieve your Conjur API key from your own Conjur deployment. For a user, call the [Login](https://docs.cyberark.com/secrets-manager-sh/12.4/en/content/developer/conjur_api_login.htm) endpoint with your Conjur username and password; the response body is the API key. The docs also document rotating personal API keys from the REST API index in [REST APIs](https://docs.cyberark.com/secrets-manager-sh/latest/en/content/developer/lp_rest_api.htm).",
        "acquisition": "manual"
      },
      "conjur_access_token": {
        "type": "bearer",
        "label": "Conjur access token",
        "setup": "Exchange a Conjur API key or password for a short-lived access token using the Authenticate API. The auth overview says Conjur accepts password, API key, or access token, and that access tokens obtained via the Authenticate API are then sent in the HTTP `Authentication` header as `Token token=...`; see [Authenticate using REST APIs](https://docs.cyberark.com/secrets-manager-sh/13.4/en/content/developer/conjur_auth_rest_apis.htm). The CLI can also mint and format this header with `conjur authn authenticate -H` per the same page.",
        "acquisition": "manual"
      }
    },
