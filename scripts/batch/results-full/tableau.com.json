        "label": "Tableau username and password",
        "generateUrl": "https://help.tableau.com/current/api/rest_api/en-us/REST/rest_api_ref_authentication.htm",
        "setup": "Use your Tableau account username and password to sign in through the REST API. Tableau notes this is available for quick manual sign-in and, for administrators, impersonation flows. After sign-in, you exchange these credentials for a short-lived `X-Tableau-Auth` token.",
        "acquisition": "manual"
      },
      "tableau_connected_app_jwt": {
        "type": "jwt",
        "label": "Tableau connected app JWT",
        "generateUrl": "https://help.tableau.com/current/server/en-us/connected_apps.htm",
        "setup": "Create or use a Tableau connected app, then mint a JSON Web Token (JWT) with the Tableau-required scope for the API call. Tableau documents connected apps JWTs for REST API sign-in and for the Metadata API. The JWT is exchanged for a Tableau auth token used on subsequent requests.",
        "acquisition": "manual"
      },
