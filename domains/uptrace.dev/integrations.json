{
  "domain": "uptrace.dev",
  "summary": "Uptrace exposes an authenticated JSON REST API, authenticated MCP server, Terraform CLI provider, and source-map upload/list/delete HTTP endpoints; auth uses a user API token or project DSN/token depending on surface.",
  "surfaces": [
    {
      "authStatus": "required",
      "name": "Uptrace JSON API",
      "slug": "uptrace-json-api",
      "type": "http",
      "url": "https://api.uptrace.dev/"
    },
    {
      "authStatus": "required",
      "name": "Uptrace MCP server",
      "slug": "uptrace-mcp-server",
      "type": "mcp",
      "url": "https://<your-uptrace-host>/mcp/<project_id>"
    },
    {
      "authStatus": "required",
      "command": "terraform",
      "name": "Uptrace Terraform provider",
      "slug": "uptrace-terraform-provider",
      "type": "cli"
    },
    {
      "authStatus": "required",
      "name": "Uptrace source map upload API",
      "slug": "uptrace-source-map-upload-api",
      "type": "http",
      "url": "https://api.uptrace.dev/api/v1/sourcemaps"
    }
  ]
}
