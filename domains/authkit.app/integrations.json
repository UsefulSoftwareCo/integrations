{
  "domain": "authkit.app",
  "summary": "authkit.app exposes an AuthKit/WorkOS OAuth authorization server and the WorkOS REST API; no CLI, GraphQL, or standalone MCP server was confirmed on the domain.",
  "surfaces": [
    {
      "authStatus": "required",
      "name": "AuthKit OAuth / OIDC authorization server",
      "slug": "authkit-oauth-oidc-authorization-server",
      "type": "http",
      "url": "https://<subdomain>.authkit.app"
    },
    {
      "authStatus": "required",
      "name": "WorkOS API",
      "slug": "workos-api",
      "type": "http",
      "url": "https://api.workos.com"
    },
    {
      "authStatus": "none",
      "name": "AuthKit MCP authorization metadata",
      "slug": "authkit-mcp-authorization-metadata",
      "type": "mcp",
      "url": "https://<subdomain>.authkit.app/.well-known/oauth-protected-resource"
    }
  ]
}
