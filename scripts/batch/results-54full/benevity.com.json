    "summary": "Benevity exposes a documented REST API with an OpenAPI spec plus a nonprofit-focused MCP server; the REST API uses OAuth 2.0 client credentials to obtain bearer tokens.",
    "description": "Benevity provides an enterprise impact platform for corporate giving, volunteering, grants, and related social-impact programs. It also maintains a large database of vetted nonprofits and charitable causes used across its platform.",
    "credentials": {
      "benevity_api_client": {
        "type": "compound",
        "label": "Benevity API client credentials (client ID, client secret, and approved scopes)",
        "generateUrl": "https://www.benevity.com/request-a-demo",
        "setup": "Request API access through [Benevity's access request form](https://www.benevity.com/request-a-demo). After approval, Benevity sends your `client-id`, `client-secret`, and authorized `scopes` by secure email. Existing Spark clients can request API access through their Client Success Manager, as described in the [Implementation Guides](https://developer.benevity.org/guides/) and [Obtaining Access](https://developer.benevity.org/guides/obtaining-access/obtaining-access.html)."
      },
      "benevity_access_token": {
        "type": "oauth2_cc",
        "label": "Benevity OAuth 2.0 client-credentials access token",
        "generateUrl": "https://www.benevity.com/request-a-demo",
        "setup": "First obtain Benevity-issued `client-id`, `client-secret`, and approved `scope` values via [Benevity's access request form](https://www.benevity.com/request-a-demo). Then request a token from `https://api.benevity.org/oauth2/token` (or the staging host) using OAuth 2.0 client credentials: send `Authorization: Basic base64(client_id:client_secret)`, `Content-Type: application/x-www-form-urlencoded`, `grant_type=client_credentials`, and `scope=benevity/api` as shown in the [Authorization guide](https://developer.benevity.org/guides/authorization/authorize.html). The returned bearer token is valid for 3600 seconds and should be reused until near expiry."
      }
