      "transloadit_auth_secret": {
        "type": "basic",
        "label": "Transloadit Auth Secret",
        "generateUrl": "https://transloadit.com/c/credentials/",
        "setup": "Go to the [Credentials](https://transloadit.com/c/credentials/) page and copy the workspace `Auth Secret` next to your Auth Key. Use it to generate request signatures (HMAC-SHA384) and for SDK/CLI auth flows that need both key and secret."
