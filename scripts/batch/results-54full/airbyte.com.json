    "summary": "Mapped 2 HTTP APIs (Airbyte API and Airbyte Agents API), 3 MCP servers (Agent MCP, Knowledge MCP, Replication MCP), and 1 CLI, with bearer/OAuth, CLI login/env, and Google-sign-in auth documented from Airbyte’s public docs.",
    "credentials": {
      "airbyte_cloud_access_token": {
        "type": "oauth2",
        "label": "Airbyte Cloud API access token",
        "generateUrl": "https://docs.airbyte.com/platform/using-airbyte/configuring-api-access",
        "setup": "For Airbyte Cloud or self-managed Airbyte API access, follow [Get an access token](https://docs.airbyte.com/platform/using-airbyte/configuring-api-access) from the Airbyte docs, then send the resulting bearer token in API requests to the Airbyte API base URL for your deployment. The API docs show Cloud requests using `Authorization: Bearer <YOUR_ACCESS_TOKEN>` against `https://api.airbyte.com/v1/`, and self-managed requests using the same header against `http://localhost:8000/api/public/v1/` or `<YOUR_AIRBYTE_URL>/api/public/v1/`.",
        "acquisition": "manual"
      },
      "airbyte_agents_client_creds": {
        "type": "oauth2_cc",
        "label": "Airbyte Agents client credentials",
        "generateUrl": "https://app.airbyte.ai",
        "setup": "Sign in to [Airbyte Agents](https://app.airbyte.ai), open your Profile page, and copy `AIRBYTE_CLIENT_ID` and `AIRBYTE_CLIENT_SECRET`. Exchange them at `POST https://api.airbyte.ai/api/v1/account/applications/token` to mint a short-lived application bearer token. Optionally call `POST https://api.airbyte.ai/api/v1/account/applications/scoped-token` with that bearer token to mint a workspace-scoped token.",
        "acquisition": "manual"
      },
      "airbyte_cli_saved_login": {
        "type": "compound",
        "label": "Airbyte Agent CLI saved login",
        "generateUrl": "https://app.airbyte.ai",
        "setup": "Install the CLI, then run `airbyte-agent login` for the browser flow or `airbyte-agent login --manual` on a headless machine. The CLI saves the required trio — `client_id`, `client_secret`, and `organization_id` — into `$HOME/.airbyte-agent/settings.json`.",
        "acquisition": "manual"
      },
      "airbyte_agent_mcp_oauth": {
        "type": "oauth2",
        "label": "Airbyte Agent MCP Airbyte account authorization",
        "generateUrl": "https://cloud.airbyte.com/signup",
        "setup": "Add the Agent MCP server URL `https://mcp.airbyte.ai/mcp` in your MCP client. On first connection, the client opens your browser; sign in to Airbyte and grant access to the Agent MCP. Automated probes detected the OAuth authorization and dynamic registration entry point at [Airbyte signup](https://cloud.airbyte.com/signup), with token exchange at `https://api.airbyte.com/v1/applications/token` and scope `api`.",
        "acquisition": "manual"
      },
      "airbyte_knowledge_mcp_google_login": {
        "type": "oauth2",
        "label": "Airbyte Knowledge MCP Google sign-in",
        "setup": "Connect your MCP client to `https://airbyte.mcp.kapa.ai`. On first connection, the client prompts you to sign in with a Google account. The docs state this Google authentication is only used to enforce rate limits and prevent abuse.",
        "acquisition": "manual"
      }
