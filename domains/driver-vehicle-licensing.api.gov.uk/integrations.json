{
  "domain": "driver-vehicle-licensing.api.gov.uk",
  "summary": "DVLA exposes 5 HTTP APIs on driver-vehicle-licensing.api.gov.uk: public Authentication API plus secured Vehicle Enquiry Service, Access to Driver Data, Keeper At Date Of Event, and Print Request Service; secure APIs use DVLA API key alone or API key + JWT via the Authentication API.",
  "surfaces": [
    {
      "authStatus": "required",
      "name": "Vehicle Enquiry Service",
      "slug": "vehicle-enquiry-service",
      "type": "http",
      "url": "https://driver-vehicle-licensing.api.gov.uk/vehicle-enquiry/v1/vehicles"
    },
    {
      "authStatus": "required",
      "name": "Access to Driver Data",
      "slug": "access-to-driver-data",
      "type": "http",
      "url": "https://driver-vehicle-licensing.api.gov.uk/full-driver-enquiry/v1/driving-licences/retrieve"
    },
    {
      "authStatus": "none",
      "name": "Authentication API",
      "slug": "authentication-api",
      "type": "http",
      "url": "https://driver-vehicle-licensing.api.gov.uk/thirdparty-access/v1"
    },
    {
      "authStatus": "required",
      "name": "Keeper At Date Of Event",
      "slug": "keeper-at-date-of-event",
      "type": "http",
      "url": "https://driver-vehicle-licensing.api.gov.uk/kadoe/v1/vehicle-keeper"
    },
    {
      "authStatus": "required",
      "name": "Print Request Service",
      "slug": "print-request-service",
      "type": "http",
      "url": "https://driver-vehicle-licensing.api.gov.uk/printhub-request"
    }
  ]
}
