{
  "domain": "goauthentik.io",
  "summary": "authentik exposes one OpenAPI-based HTTP API plus two authenticated WebSocket surfaces; auth works with API tokens, OAuth access tokens scoped `goauthentik.io/api`, or session cookies.",
  "surfaces": [
    {
      "authStatus": "required",
      "name": "authentik API",
      "slug": "authentik-api",
      "spec": "https://api.goauthentik.io/schema.yml",
      "type": "http",
      "url": "https://_authentik.company_/api/v3/"
    },
    {
      "authStatus": "required",
      "name": "authentik WebSocket client updates",
      "slug": "authentik-websocket-client-updates",
      "type": "mcp",
      "url": "https://_authentik.company_/ws/client/"
    },
    {
      "authStatus": "required",
      "name": "authentik WebSocket outpost",
      "slug": "authentik-websocket-outpost",
      "type": "mcp",
      "url": "https://_authentik.company_/ws/outpost/<outpost-uuid>/"
    }
  ]
}
