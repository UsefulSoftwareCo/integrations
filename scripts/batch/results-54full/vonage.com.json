    "summary": "Vonage exposes five documented Vonage Business Cloud HTTP APIs (Account, Extension, Reports, User, and Integration Suite) authenticated with a required bearer token tied to subscribed API suites, plus a public documentation MCP server, a credentialed Server API Bindings MCP server, and the Vonage CLI, both configured with your Vonage API key/secret together with an application ID/private key.",
    "credentials": {
      "vbc_bearer_token": {
        "type": "bearer",
        "label": "Vonage Business Cloud bearer access token",
        "generateUrl": "https://businesssupport.vonage.com/contactus",
        "setup": "For Vonage Business Cloud APIs, your application must be subscribed to the relevant API suite (for example Provisioning, Reports, or Vonage Integration Suite) before use. The published OpenAPI specs require `bearerAuth`, but the public docs scraped here do not show a self-service token mint page. Start from [Vonage Business Cloud Support](https://businesssupport.vonage.com/contactus) to request access and token issuance details for your tenant/application.",
        "acquisition": "manual"
      },
      "vonage_api_key_secret": {
        "type": "basic",
        "label": "Vonage API key and API secret",
        "generateUrl": "https://dashboard.nexmo.com/settings",
        "setup": "Sign up for a Vonage account, then open [Account Settings](https://dashboard.nexmo.com/settings) in the dashboard. Vonage creates an API key and API secret for your account automatically. Use them directly where a product accepts basic auth, or pass them to tools that need `API_KEY`/`API_SECRET`. Keep the secret private.",
        "acquisition": "manual"
      },
      "vonage_application_jwt": {
        "type": "jwt",
        "label": "Vonage application JWT backed by application ID and private key",
        "generateUrl": "https://dashboard.vonage.com/applications",
        "setup": "In the [Vonage Dashboard Applications](https://dashboard.vonage.com/applications), create or open an application and obtain its application ID plus private key. Use those to generate a JWT; Vonage notes you can generate one with the [Vonage CLI guide](https://developer.vonage.com/en/getting-started/tools/cli) or the [online JWT generator](https://developer.vonage.com/jwt). JWT auth is recommended for APIs such as Messages and Voice.",
        "acquisition": "manual"
      },
      "vonage_app_id_private_key": {
        "type": "compound",
        "label": "Vonage application ID and private key",
        "generateUrl": "https://dashboard.vonage.com/applications",
        "setup": "Open [Vonage Dashboard Applications](https://dashboard.vonage.com/applications) and create or select an application. Copy the application ID and download or regenerate the private key when available. These are used together by the CLI and tooling MCP server, and can also be used to mint Vonage JWTs.",
        "acquisition": "manual"
      }
