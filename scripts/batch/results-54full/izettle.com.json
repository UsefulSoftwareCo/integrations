    "summary": "Zettle exposes multiple OAuth-protected HTTP APIs for POS integrations: Product Library, Inventory, Finance, Purchase, Image, Gift Card, plus a Reader Connect REST API with unclear documented auth details; no public GraphQL, MCP server, or CLI surfaced.",
    "description": "Zettle by PayPal provides point-of-sale and payment tools for merchants, including product catalog, inventory, purchases, finance data, gift cards, and card-reader integrations. Its developer platform lets integrators connect POS and commerce systems to those merchant services.",
    "credentials": {
      "zettle_oauth_app": {
        "type": "oauth2",
        "label": "Zettle app credentials (client ID and, for confidential apps, client secret) used to obtain OAuth access tokens",
        "generateUrl": "https://developer.zettle.com/dashboard",
        "setup": "Create app credentials in the [Zettle Developer Portal dashboard](https://developer.zettle.com/dashboard). For a partner-hosted app, follow [Create credentials for a partner-hosted app](https://developer.zettle.com/docs/get-started/user-guides/create-app-credentials/create-credentials-partner-hosted-app): sign in, click **Create app credentials**, choose **Public API credentials**, enter your HTTPS redirect URI, create the app, and download the `client_id` and `client_secret`. Zettle recommends the OAuth authorization code flow with PKCE as the default; the same dashboard-created app credentials supply the `client_id` for PKCE and confidential code-grant flows.",
        "acquisition": "manual"
      },
      "zettle_api_key": {
        "type": "jwt",
        "label": "Zettle self-hosted app API key (JWT assertion) exchanged for OAuth access tokens",
        "setup": "For self-hosted integrations, ask each merchant user to create an API key in Zettle as described in the OAuth API docs and the linked self-hosted app guides. In the [OAuth API reference](https://developer.zettle.com/docs/api/oauth/api-reference), the assertion grant uses a merchant-created API key (`assertion`) together with the self-hosted app `client_id` to request an access token from `https://oauth.zettle.com/token`. The key can be revoked by the merchant in `my.zettle.com`.",
        "acquisition": "manual"
      },
      "zettle_access_token": {
        "type": "bearer",
        "label": "Zettle OAuth access token used to call Zettle APIs",
        "generateUrl": "https://oauth.zettle.com/token",
        "setup": "First create Zettle app credentials in the [Developer Portal](https://developer.zettle.com/dashboard). Then obtain an access token through the [OAuth API](https://developer.zettle.com/docs/api/oauth/overview): either authorization code with PKCE, authorization code with `client_secret`, or assertion grant using a merchant-created API key. Send the resulting token as `Authorization: Bearer <token>` in API requests, as shown in [Include access token and tracking identifier in API requests](https://developer.zettle.com/docs/api/oauth/user-guides/include-access-token-tracking-id-in-api-requests).",
        "acquisition": "manual"
      }
    },
