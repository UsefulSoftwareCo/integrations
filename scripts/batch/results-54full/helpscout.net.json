        "generateUrl": "https://secure.helpscout.net",
        "setup": "In Help Scout, open your profile from the top-right avatar/person menu, go to **Your Profile** → **Authentication** → **API Keys**, then generate or regenerate your Docs API key. This key is available only to users with the `Docs: Create new, edit settings & Collections` permission. Use the key as the HTTP Basic username with any dummy password such as `X`. See [Docs API overview](https://developer.helpscout.com/docs-api/)."
      },
      "hs_oauth_app": {
        "type": "oauth2",
        "label": "Inbox API OAuth app and access token",
        "generateUrl": "https://secure.helpscout.net",
