    "credentials": {
      "kensho_refresh_token": {
        "type": "oauth2",
        "label": "Kensho API refresh token",
        "generateUrl": "https://docs.kensho.com/authentication/personal-token",
        "setup": "For testing and development, open the product account page for the API you want to use and copy a refresh token. The docs explicitly list [Scribe account](https://scribe.kensho.com/account) and note that each Kensho API has its own refresh-token endpoint, so the token is product-specific. Use that refresh token to mint short-lived access tokens before API calls, e.g. `GET /oauth2/refresh?refresh_token=...` on the product host as shown in the [authentication quickstart](https://docs.kensho.com/authentication/personal-token). For the LLM-ready API specifically, go to [LLM-ready API manual login](https://kfinance.kensho.com/manual_login/), sign in with your LLM-ready API Okta credentials, and copy the refresh token as shown in the [LLM-ready API authentication guide](https://docs.kensho.com/llmreadyapi/python-library/kf-authentication).",
        "acquisition": "manual"
      },
      "kensho_keypair": {
        "type": "app",
        "label": "Kensho client ID + RSA keypair",
        "generateUrl": "https://docs.kensho.com/authentication/keypair",
        "setup": "For production access, generate an RSA keypair locally, then email Kensho your public key and the application(s) you need. The [production authentication guide](https://docs.kensho.com/authentication/keypair) says to generate `private.pem`/`public.pem`, send the PEM-encoded public key to [support@kensho.com](mailto:support@kensho.com), and Kensho will reply with your `Client ID`. Use the `Client ID` together with your private key to obtain short-lived access tokens. For LLM-ready API access, the product guide says to email [commercial@kensho.com](mailto:commercial@kensho.com) to obtain LLM-ready API Okta credentials, and the same page documents keypair auth in the [LLM-ready API authentication guide](https://docs.kensho.com/llmreadyapi/python-library/kf-authentication).",
        "acquisition": "manual"
      },
      "spg_oauth_client": {
        "type": "oauth2",
        "label": "S&P Global OAuth client credentials",
        "generateUrl": "https://docs.kensho.com/adaptive-retrieval/mcp",
        "setup": "For Adaptive Retrieval MCP access, request S&P Global OAuth credentials by emailing [commercial@kensho.com](mailto:commercial@kensho.com), as stated in the [Adaptive Retrieval MCP guide](https://docs.kensho.com/adaptive-retrieval/mcp). The guide says you will need your S&P Global `CLIENT_ID` and then complete the OAuth flow from your MCP client or MCP Inspector against the server at `https://grounding.kensho.com/integrations/v2/mcp`.",
