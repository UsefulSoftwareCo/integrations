      "factset_api_key": {
        "type": "basic",
        "label": "FactSet API key used with username-serial via HTTP Basic auth",
        "generateUrl": "https://developer.factset.com/api-authentication",
        "setup": "Log in to the [FactSet Developer Portal](https://developer.factset.com/), open [API Authentication](https://developer.factset.com/api-authentication) (Profile → API Authentication), click `Create`, choose `API Key`, select the FactSet `username-serial` account, set the allowed IP range(s), and submit. FactSet shows the API key once; save it securely. Use your FactSet `username-serial` as the Basic auth username and the generated API key as the Basic auth password."
      },
      "factset_oauth_app": {
        "type": "oauth2",
        "label": "FactSet OAuth 2.0 application",
        "generateUrl": "https://developer.factset.com/api-authentication",
        "setup": "Log in to the [FactSet Developer Portal](https://developer.factset.com/), open [API Authentication](https://developer.factset.com/api-authentication) (Profile → API Authentication), click `Create`, and choose an OAuth 2.0 application type. FactSet supports public and confidential clients, including authorization code and client credentials flows. For confidential clients, the easiest path is to let FactSet generate a key pair for you when creating the app; for production, FactSet recommends uploading your own public key in JWK format. After creation, download the application configuration and use it to obtain OAuth access tokens for FactSet APIs."
      }
