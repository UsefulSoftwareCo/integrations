      "dremio_pat": {
        "type": "api_key",
        "label": "Dremio personal access token (PAT)",
        "generateUrl": "https://docs.dremio.com/dremio-cloud/security/authentication/personal-access-token/",
        "setup": "In Dremio Cloud, open [Account Settings → Personal Access Tokens](https://docs.dremio.com/dremio-cloud/security/authentication/personal-access-token/) and click **Generate Token**. Copy the token immediately; it is shown only once. For Dremio Enterprise, users create PATs from [Account Settings → Personal Access Tokens](https://docs.dremio.com/current/security/authentication/personal-access-tokens/) after PAT support is enabled by an admin.",
        "acquisition": "manual"
      },
      "dremio_oauth_app": {
        "type": "oauth2",
        "label": "Dremio OAuth application client ID",
        "generateUrl": "https://docs.dremio.com/dremio-cloud/security/authentication/app-authentication/oauth-apps/",
        "setup": "In Dremio Cloud, go to [Organization → OAuth Applications](https://docs.dremio.com/dremio-cloud/security/authentication/app-authentication/oauth-apps/) and click **Add Application** (or **Create OAuth Application** in MCP setup docs). Choose the application type, add the redirect URI(s), create the app, and copy the `Client ID`. The hosted MCP setup docs say to leave the client secret blank for native-app connectors such as Claude or ChatGPT.",
        "acquisition": "manual"
      },
      "dremio_service_client": {
        "type": "compound",
        "label": "Dremio service user client credentials (client ID + client secret)",
        "generateUrl": "https://docs.dremio.com/current/reference/api/oauth-token/",
        "setup": "Create a Dremio service user, then use its `client_id` and `client_secret` to request an OAuth access token from Dremio's `/oauth/token` endpoint as described in [OAuth Token Enterprise](https://docs.dremio.com/current/reference/api/oauth-token/). The docs point to [User Management](https://docs.dremio.com/current/security/authentication/users/) for creating service users. Use `grant_type=client_credentials` and `scope=dremio.all`.",
        "acquisition": "manual"
      }
