    "summary": "authkit.app is AuthKit by WorkOS and exposes WorkOS’s authenticated developer surfaces: a REST API at `https://api.workos.com`, a Client GraphQL API token flow via the same API, and the `workos` npm CLI; no standalone authkit.app-native API surface was documented beyond AuthKit-hosted OAuth metadata for tenant subdomains.",
    "description": "AuthKit is WorkOS’s user authentication product for SaaS applications, providing hosted and embeddable sign-in flows with email/password, social login, MFA, magic auth, and enterprise SSO. The authkit.app domain is the AuthKit product site and tenant-hosted AuthKit domain pattern used within WorkOS.",
    "credentials": {
      "workos_api_key": {
        "type": "bearer",
        "label": "WorkOS API key",
        "generateUrl": "https://dashboard.workos.com/api-keys",
        "setup": "In the [WorkOS Dashboard API Keys page](https://dashboard.workos.com/api-keys), create or copy an environment API key (`sk_test_...` or `sk_live_...`). For zero-account temporary environments, you can also provision one automatically by running [`npx workos@latest install`](https://workos.com/docs/authkit/cli-installer) or by calling [`POST /x/one-shot-environments`](https://workos.com/auth.md); that returns an `apiKey` you can use immediately.",
        "acquisition": "manual"
      },
      "workos_client_token": {
        "type": "bearer",
        "label": "WorkOS Client GraphQL API token",
        "setup": "Mint this short-lived token from the WorkOS REST API by calling [`POST /client/token`](https://workos.com/docs/reference) with your WorkOS API key and the target `organization_id` and `user_id`. The response returns `token`, which is the bearer token for the Client GraphQL API.",
        "acquisition": "manual"
      },
      "workos_cli_session": {
        "type": "oauth2",
        "label": "WorkOS CLI login session",
        "setup": "Install the CLI with [`npx workos@latest`](https://workos.com/docs/authkit/cli-installer) or [`npm install -g workos`](https://www.npmjs.com/package/workos), then run `workos auth login` or `workos install`. The CLI opens a browser for secure WorkOS sign-in and stores an authenticated session for subsequent commands. Many commands can also be pointed at an API key directly with `--api-key`.",
        "acquisition": "manual"
      }
    },
