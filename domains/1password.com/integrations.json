    {
      "authStatus": "required",
      "name": "1Password Connect REST API",
      "slug": "1password-connect-rest-api",
      "type": "http",
      "url": "https://<connect-server>/"
    },
    {
      "authStatus": "required",
      "command": "op",
      "name": "1Password CLI",
      "slug": "1password-cli",
      "type": "cli"
    },
    {
      "authStatus": "required",
      "name": "1Password Events API",
      "slug": "1password-events-api",
