    "summary": "Sentry exposes a REST Web API, an OAuth-protected MCP server at `https://mcp.sentry.dev/mcp`, and two CLIs (`sentry` and `sentry-cli`), authenticated with Sentry auth tokens or OAuth depending on the surface.",
    "description": "Sentry is an application monitoring and observability platform for tracking errors, performance, logs, traces, and related debugging data in software projects. It provides hosted services and tooling for developers to inspect and act on issues across their applications.",
    "credentials": {
      "sentry_auth_token": {
        "type": "bearer",
        "label": "Sentry auth token (organization/personal/internal integration token)",
        "generateUrl": "https://sentry.io/orgredirect/organizations/:orgslug/settings/auth-tokens/",
        "setup": "Create a token in Sentry from [Auth Tokens docs](https://docs.sentry.io/account/auth-tokens/). For CI and most CLI/API use, create an organization token under [Organization Tokens](https://sentry.io/orgredirect/organizations/:orgslug/settings/auth-tokens/). For user-bound API access, create a personal token from **User settings → Personal Tokens** as described in [API authentication](https://docs.sentry.io/api/auth/). For custom organization-scoped API permissions, create an internal integration as described in [Internal Integrations](https://docs.sentry.io/integrations/integration-platform/#internal-integrations). Use the token as `Authorization: Bearer <token>`."
      },
      "sentry_oauth_app": {
        "type": "oauth2",
        "label": "Sentry OAuth app (client ID and client secret)",
        "generateUrl": "https://docs.sentry.io/product/partnership-platform/oauth-integration/",
        "setup": "To get OAuth client credentials, Sentry must register your application. Follow [OAuth Integration](https://docs.sentry.io/product/partnership-platform/oauth-integration/) and contact `partnership-platform@sentry.io` with your client name, redirect URIs, allowed origins, home page URL, privacy policy URL, terms URL, and required scopes. Sentry then provides your `client_id` and `client_secret`. Users authorize at `https://sentry.io/oauth/authorize/`, and your app exchanges the code at `https://sentry.io/oauth/token/` as described in [API authentication](https://docs.sentry.io/api/auth/#oauth2)."
      }
