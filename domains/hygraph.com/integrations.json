{
  "domain": "hygraph.com",
  "summary": "Hygraph exposes a GraphQL Content API plus a hosted MCP server; both use PAT bearer auth, and the Content API can also be made public via project-configured API permissions.",
  "surfaces": [
    {
      "authStatus": "required",
      "name": "Hygraph Content API",
      "slug": "hygraph-content-api",
      "spec": "introspection",
      "type": "graphql",
      "url": "https://${region}.hygraph.com/v2/${projectId}/${environment}"
    },
    {
      "authStatus": "required",
      "name": "Hygraph MCP Server",
      "slug": "hygraph-mcp-server",
      "type": "mcp",
      "url": "https://mcp-{REGION}.hygraph.com/{PROJECT_ID}/{ENVIRONMENT}/mcp"
    },
    {
      "authStatus": "unknown",
      "name": "Hygraph API Playground",
      "slug": "hygraph-api-playground",
      "type": "graphql",
      "url": "https://${region}.hygraph.com/v2/${projectId}/${environment}"
    }
  ]
}
