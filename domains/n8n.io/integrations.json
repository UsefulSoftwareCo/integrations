{
  "domain": "n8n.io",
  "summary": "n8n exposes a public REST API, a CLI wrapper over that API, and an instance-level MCP server; all are authenticated primarily with an n8n API key, with MCP also supporting a personal access token.",
  "surfaces": [
    {
      "authStatus": "required",
      "name": "n8n Public REST API",
      "slug": "n8n-public-rest-api",
      "spec": "https://internal.users.n8n.cloud/api/v1/openapi.yml",
      "type": "http",
      "url": "https://<your-instance>/api/v1"
    },
    {
      "authStatus": "required",
      "command": "n8n-cli",
      "name": "n8n CLI",
      "slug": "n8n-cli",
      "type": "cli"
    },
    {
      "authStatus": "required",
      "name": "n8n instance-level MCP server",
      "slug": "n8n-instance-level-mcp-server",
      "type": "mcp",
      "url": "https://<your-instance>/mcp"
    }
  ]
}
