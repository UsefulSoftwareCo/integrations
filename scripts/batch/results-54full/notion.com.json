        "generateUrl": "https://app.notion.com/developers/connections",
        "setup": "Create an internal connection in the [Developer portal](https://app.notion.com/developers/connections): choose **Internal connections**, create a new connection, then open its **Configuration** tab and copy the **Installation access token**. Share the needed pages/databases with the connection via **Content access** or the page’s **Connections** menu before using the token.",
        "acquisition": "manual"
      },
      "notion_pat": {
        "type": "bearer",
        "label": "Notion personal access token (PAT)",
        "generateUrl": "https://www.notion.so/developers",
        "setup": "Open the [Developer portal](https://www.notion.so/developers), create a personal access token, choose its workspace and capabilities, then copy the token secret. PATs are user-scoped and use the creator’s page permissions. For CLI unattended use, export it as `NOTION_API_TOKEN`.",
        "acquisition": "manual"
      },
      "notion_oauth_app": {
        "type": "oauth2",
        "label": "Notion public connection OAuth app",
        "generateUrl": "https://app.notion.com/developers/connections",
        "setup": "Create a public connection in the [Developer portal](https://app.notion.com/developers/connections): choose **Public connections**, create the connection, configure its redirect URI and capabilities in **Configuration**, then use the connection’s authorization URL from that tab to run the OAuth install flow. Exchange the returned authorization code for an access token and store the returned refresh token for renewal.",
        "acquisition": "manual"
      },
      "notion_org_bot_token": {
        "type": "bearer",
        "label": "Notion Admin API organization bot token",
        "generateUrl": "https://www.notion.com/help/organization-level-controls",
        "setup": "An organization owner can create the token in the [organization console](https://www.notion.com/help/organization-level-controls). Create an organization bot token, choose the needed Admin API scopes, then copy the token secret. The Admin API is only available for enterprise organizations/workspaces.",
        "acquisition": "manual"
      },
      "notion_cli_session": {
        "type": "oauth2",
        "label": "Notion CLI login session",
        "generateUrl": "https://developers.notion.com/cli/get-started/authentication",
        "setup": "Install the CLI, then run `ntn login` and complete the browser authorization flow. On headless systems, run `ntn login --no-browser`, approve the printed URL/code in a browser, then run `ntn login poll`. The CLI stores the workspace-scoped token in your OS keychain by default.",
        "acquisition": "manual"
      }
