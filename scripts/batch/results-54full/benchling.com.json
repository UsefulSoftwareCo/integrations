    "description": "Benchling is a life sciences R&D platform for managing scientific data such as sequences, registry entities, assay results, inventory, notebook entries, and workflows. It also offers a data warehouse for analytics and event-driven integration features for enterprise tenants.",
    "credentials": {
      "api_key": {
        "type": "basic",
        "label": "User API key",
        "generateUrl": "https://docs.benchling.com/docs/authentication",
        "setup": "In Benchling, open your profile/account settings and generate an API key in **Profile Settings**. Benchling documents that API keys are generated from your profile and can be rotated from profile settings; use your tenant URL such as `https://<your-company>.benchling.com` when calling the API. See [Authentication](https://docs.benchling.com/docs/authentication.md) and [Access Benchling’s Developer Platform and Documentation Base](https://help.benchling.com/hc/en-us/articles/9714802977805-Access-Benchling-s-Developer-Platform-and-Documentation-Base)."
      },
      "app_oauth": {
        "type": "oauth2_cc",
        "label": "Benchling app client credentials",
        "generateUrl": "https://docs.benchling.com/docs/getting-started-benchling-apps",
        "setup": "Create a Benchling app from your tenant’s **Developer Console** (`Feature settings` → `Developer Console` → Apps). From the app settings page, obtain the app’s `client_id` and `client_secret`; Benchling says apps use the OAuth 2.0 client-credentials flow to call `/token`, and app secrets can be rotated from the Apps page. See [Getting Started with Benchling Apps](https://docs.benchling.com/docs/getting-started-benchling-apps.md), [Authentication](https://docs.benchling.com/docs/authentication.md), and [Access Benchling’s Developer Platform and Documentation Base](https://help.benchling.com/hc/en-us/articles/9714802977805-Access-Benchling-s-Developer-Platform-and-Documentation-Base)."
      },
      "oidc_id_token": {
        "type": "bearer",
        "label": "OIDC ID token from your configured identity provider",
        "generateUrl": "https://docs.benchling.com/docs/authentication",
        "setup": "Have Benchling enable OIDC authentication for your enterprise tenant by contacting [support@benchling.com](mailto:support@benchling.com), then configure a trusted OpenID Connect identity provider that includes an `email` claim. Your integration authenticates to that IdP and uses the returned ID token as `Authorization: Bearer ...` when calling Benchling. See [Authentication](https://docs.benchling.com/docs/authentication.md)."
      },
      "warehouse_login": {
        "type": "basic",
        "label": "Warehouse PostgreSQL username/password",
        "generateUrl": "https://docs.benchling.com/docs/getting-started",
        "setup": "In Benchling **Account Settings**, under **Warehouse credentials**, click **Create credentials** to generate a warehouse username/password. If you do not see that option, contact your Benchling Customer Success Manager to enable warehouse access. Use the credentials with your warehouse PostgreSQL connection over TLS. See [Overview & Getting started](https://docs.benchling.com/docs/getting-started.md)."
      }
