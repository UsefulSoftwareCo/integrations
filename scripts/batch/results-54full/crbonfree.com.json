      "crbonfree_api_key": {
        "type": "api_key",
        "label": "CrbonFree API key",
        "generateUrl": "https://ai.crbonfree.com/docs",
        "setup": "Easiest path: run [`npx @crbonfree/sdk login`](https://www.npmjs.com/package/@crbonfree/sdk?activeTab=readme), [`npx @crbonfree/mcp login`](https://www.npmjs.com/package/@crbonfree/mcp), or `crbonfree login` after installing the [Python package](https://pypi.org/project/crbonfree/). The login flow opens a browser, creates/signs into your account, generates an API key, and saves it to `~/.crbonfree/credentials`. For manual/API issuance, the API spec says long-lived keys are issued via `POST /api/v1/api-keys` and look like `ck_live_…`.",
        "acquisition": "manual"
      },
