{
  "domain": "prismic.io",
  "summary": "Prismic exposes public Repository API plus authenticated Content API, GraphQL API, and MCP server; developer access is primarily via @prismicio client packages.",
  "surfaces": [
    {
      "authStatus": "required",
      "name": "Prismic Content API",
      "slug": "prismic-content-api",
      "type": "http",
      "url": "https://your-repo-name.cdn.prismic.io/api/v2/documents/search"
    },
    {
      "authStatus": "none",
      "name": "Prismic Repository API",
      "slug": "prismic-repository-api",
      "type": "http",
      "url": "https://your-repo-name.cdn.prismic.io/api/v2"
    },
    {
      "authStatus": "required",
      "name": "Prismic GraphQL API",
      "slug": "prismic-graphql-api",
      "spec": "introspection",
      "type": "graphql",
      "url": "https://your-repo-name.cdn.prismic.io/graphql"
    },
    {
      "authStatus": "required",
      "name": "Prismic MCP Server",
      "slug": "prismic-mcp-server",
      "type": "mcp",
      "url": "https://mcp.prismic.io/mcp"
    },
    {
      "authStatus": "none",
      "command": "npx @prismicio/client",
      "name": "Prismic API packages",
      "slug": "prismic-api-packages",
      "type": "cli"
    }
  ]
}
