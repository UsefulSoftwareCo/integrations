    "summary": "Basecamp exposes three documented REST API surfaces—Basecamp 3, Basecamp 2, and Basecamp Classic—plus an official `basecamp` CLI; auth is via Launchpad OAuth for Basecamp 3 and optionally Basecamp 2/Classic, with Basic/API-token auth also supported on older APIs.",
    "description": "Basecamp is a project management and team collaboration product from 37signals. Its product family includes multiple generations of Basecamp with separate APIs, along with an official CLI for terminal and AI-agent access.",
    "credentials": {
      "launchpad_oauth_app": {
        "type": "oauth2",
        "label": "Launchpad OAuth app",
        "generateUrl": "https://launchpad.37signals.com/integrations",
        "setup": "Register an integration in [Launchpad Integrations](https://launchpad.37signals.com/integrations) (or start at [new integration](https://launchpad.37signals.com/integrations/new)). Basecamp assigns a `client_id` and `client_secret`; you also configure a `redirect_uri`. The shared auth guide says to use `https://launchpad.37signals.com/authorization/new` for authorization and `https://launchpad.37signals.com/authorization/token` for token exchange/refresh."
      },
      "bc2_basic": {
        "type": "basic",
        "label": "Basecamp 2 account username/password",
        "setup": "Use your own Basecamp 2 account login for private integrations. The Basecamp 2 API docs explicitly allow HTTP Basic auth for your own account and say not to ask other users for their passwords. See the [Basecamp 2 API README](https://github.com/basecamp/bcx-api/blob/master/README.md) and shared [authentication guide](https://github.com/basecamp/api/blob/master/sections/authentication.md)."
      },
      "classic_api_token": {
        "type": "api_key",
        "label": "Basecamp Classic API token",
        "generateUrl": "https://basecamphq.com",
        "setup": "Log in to your Basecamp Classic account, open **My Info**, then click **Show your tokens** under **Authentication tokens** to reveal your API token. The Classic API README says this token is used via HTTP Basic auth with the token as the username and `X` as the password."
      },
      "basecamp_cli_login": {
        "type": "oauth2",
        "label": "Basecamp CLI stored OAuth login",
        "setup": "Install the CLI, then run `basecamp auth login`. The CLI opens a browser for OAuth and stores credentials securely in the system keychain or CLI config. See the [Basecamp CLI README](https://github.com/basecamp/basecamp-cli/blob/main/README.md) and [skills install guide](https://github.com/basecamp/skills/blob/main/install.md)."
      }
