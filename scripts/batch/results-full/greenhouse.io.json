        "type": "oauth2_cc",
        "label": "Harvest API credential",
        "generateUrl": "https://support.greenhouse.io/hc/en-us/articles/5888163769883",
        "setup": "In Greenhouse Recruiting, go to **Configure** → **Dev Center** → **API Credential Management** → **Create new API credentials**. Choose **Harvest** or **Harvest v3 (OAuth)**, pick the integration partner, then save/store the credential. For v3, the client secret is shown only once; copy it immediately. Use the credential with the Harvest API docs at [harvestdocs.greenhouse.io](http://harvestdocs.greenhouse.io).",
        "acquisition": "manual"
      },
      "gh_job_board_token": {
        "type": "basic",
        "label": "Job Board token / API key",
        "generateUrl": "https://support.greenhouse.io/hc/en-us/articles/5888210160155",
        "setup": "In Greenhouse Recruiting, go to **Configure** → **Job Board & Posts** → your job board → **Edit Board Settings**. Copy the job board URL; the final path segment is your job board token. Use it as the Basic Auth username for the application submission endpoint, after Base64-encoding `token:`.",
        "acquisition": "manual"
      },
      "gh_ingestion_oauth": {
        "type": "oauth2",
        "label": "Candidate Ingestion OAuth credential",
        "generateUrl": "https://developers.greenhouse.io/candidate-ingestion.html",
        "setup": "Provide Greenhouse your application name, application URL, callback URL, and logo. Greenhouse returns a consumer key, consumer secret, authorize URL, and token URL; your app then runs the OAuth flow and stores the resulting access token.",
        "acquisition": "manual"
      },
      "gh_ingestion_basic": {
        "type": "basic",
        "label": "Candidate Ingestion partner API key + service user",
        "generateUrl": "https://developers.greenhouse.io/candidate-ingestion.html",
        "setup": "Use the partner API key together with a Greenhouse service user. Send Basic Auth with the API key as the username and an empty password, and include `On-Behalf-Of: <service-user-email>` on every request.",
        "acquisition": "manual"
      },
      "gh_assessment_partner_key": {
        "type": "basic",
        "label": "Assessment Partner API key",
        "generateUrl": "https://developers.greenhouse.io/assessment.html",
        "setup": "Greenhouse asks the assessment partner for a sample API key and uses that key as the Basic Auth username when calling the partner's endpoints. Provide Greenhouse the `list_tests`, `send_test`, `test_status`, and `response_error` endpoint URLs during setup.",
        "acquisition": "manual"
      }
