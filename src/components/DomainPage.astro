---
// The domain page, markup + head — rendered two ways with zero drift:
//  - prerendered at build ([domain].astro) with baseline discovery data when a
//    concrete baseline exists; otherwise the island mounts idle and offers
//    "Map integration surface".
//  - SSR'd in the worker (ssr/[domain].astro) when stored discovery exists in
//    KV; `initialData` bakes the discovered map into the HTML so the page
//    arrives already in the "done" state — no idle-button flash.
import Base from "~/layouts/Base.astro";
import Breadcrumb from "~/components/Breadcrumb.astro";
import Surfaces from "~/components/Surfaces.tsx";
import { faviconUrl } from "~/lib/favicon.ts";
import { KIND_ORDER, SECTION_LABEL, SHORT_LABEL } from "~/lib/domain-labels.ts";
import { kindOf, type DiscoverData } from "~/lib/surface-sections.ts";
import type { Kind } from "~/lib/types.ts";
import "~/styles/discovery.css";

interface Props {
  domain: string;
  /** Discovery to bake in (KV or baseline fallback). */
  initialData?: DiscoverData | null;
}

const { domain, initialData = null } = Astro.props;

// Header line: counts and kinds from the discovery document only.
const surfaces = initialData?.surfaces ?? [];
const kinds = KIND_ORDER.filter((k) => surfaces.some((s) => kindOf(s.type) === k));
const count = surfaces.length;

const icon = faviconUrl(domain);
const letter = (domain[0] ?? "?").toUpperCase();

const formatList = kinds.map((k) => SECTION_LABEL[k as Kind].replace(" · ", "/")).join(", ");
const title = `${domain} — integrations`;
const description = count
  ? `${count} integration${count === 1 ? "" : "s"} for ${domain} across ${formatList} — readable by you and your agent.`
  : `Map integration surfaces for ${domain} — APIs, MCP servers, GraphQL, and CLI.`;
const meta = [
  `${count} integration${count === 1 ? "" : "s"}`,
  ...kinds.map((k) => SHORT_LABEL[k as Kind]),
].join(" · ");
---

<Base title={title} description={description} path={`/${domain}/`} ogImagePath={`/og/${encodeURIComponent(domain)}.png`}>
  <div class="container">
    <article>
      <Breadcrumb
        segments={[
          { label: "registry", href: "/" },
          { label: domain },
        ]}
      />

      <header class="head">
        <div class="favicon">
          <span class="fav-letter">{letter}</span>
          {icon && <img src={icon} width="22" height="22" alt="" loading="lazy" onerror="this.remove()" />}
        </div>
        <div class="head-body">
          <h1>{domain}</h1>
          <p class="meta">{meta}</p>
        </div>
      </header>

      <Surfaces domain={domain} initialData={initialData} client:visible />
    </article>
  </div>
</Base>
