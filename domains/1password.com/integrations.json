      "type": "http",
      "url": "https://events.1password.com/api/v2"
    },
    {
      "authStatus": "required",
      "name": "1Password Partnership API",
      "slug": "1password-partnership-api",
      "spec": "https://i.1password.com/media/1password-partnership-api/partnership-api.yml",
      "type": "http",
      "url": "https://billing.1password.com/api/v1/partners/accounts"
    }
  ]
