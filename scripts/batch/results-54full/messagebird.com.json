        "generateUrl": "https://dashboard.messagebird.com/developers/access",
        "setup": "In the MessageBird dashboard, go to [Developers → API access (Access Keys)](https://dashboard.messagebird.com/developers/access) and create or copy an access key for your account/workspace. Send it on API requests in the `Authorization` header as `AccessKey <key>`. The legacy MessageBird API docs describe this as an access key used by the API Authorization framework.",
        "acquisition": "manual"
      },
      "bird_api_key": {
        "type": "api_key",
        "label": "Bird API key",
        "generateUrl": "https://bird.com/en-us/docs/guides/authentication/",
        "setup": "Create a key in the Bird dashboard under [Developers → API keys](https://bird.com/en-us/docs/guides/authentication), or programmatically via `POST /v1/api-keys` once you already have sufficient rights. Choose the minimal scopes you need; Bird shows the full key exactly once. Use it as `Authorization: Bearer bk_{region}_...` against the matching regional host.",
        "acquisition": "manual"
      },
      "bird_cli_oauth": {
        "type": "oauth2",
        "label": "Bird CLI OAuth grant",
        "generateUrl": "https://bird.com/en-us/docs/cli",
        "setup": "Install the CLI from [Bird CLI docs](https://bird.com/en-us/docs/cli), then run `bird auth login` (or `bird auth login --device` on a headless machine). This browser/device OAuth flow stores a workspace-bound token in `~/.config/bird/credentials.json` and the CLI refreshes it automatically.",
        "acquisition": "manual"
      },
      "bird_mcp_oauth": {
        "type": "oauth2",
        "label": "Bird MCP OAuth grant",
        "generateUrl": "https://bird.com/en-us/docs/ai/mcp-server",
        "setup": "Point your MCP client at [Bird's hosted MCP server docs](https://bird.com/en-us/docs/ai/mcp-server) using `https://mcp.platform.bird.com`. On first connect, the client follows Bird's MCP/OAuth discovery flow automatically: it discovers Bird's protected-resource metadata, dynamically registers, opens a browser consent screen, and obtains a refreshable OAuth bearer token scoped to the workspace and permissions you approve.",
        "acquisition": "manual"
      }
