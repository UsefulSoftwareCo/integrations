      "steadily_partner_api_key": {
        "type": "api_key",
        "label": "Steadily Partner API key",
        "generateUrl": "https://api.steadily.com/estimate-api/redoc",
        "setup": "For the Partner API, request an API key by contacting [Steadily partnerships](mailto:partnerships-team@steadily.com) as directed in the [Partner API docs](https://api.steadily.com/estimate-api/redoc)."
      },
      "steadily_rater_api_key": {
        "type": "api_key",
        "label": "Steadily Rater Quotes API key",
        "generateUrl": "https://api.steadily.com/quote-rater/redoc",
        "setup": "For the Rater Quotes API, request your agency API key by contacting [Steadily partnerships](mailto:partnerships-team@steadily.com?subject=QuoteBind+API+Key) as described in the [Rater Quotes API docs](https://api.steadily.com/quote-rater/redoc). Steadily issues a staging key first, then a production key once your integration is working."
      },
      "steadily_agent_bearer": {
        "type": "bearer",
        "label": "Steadily agent bearer token",
        "generateUrl": "https://api.steadily.com/quote-rater/redoc",
        "setup": "Generate this token via the Rater Quotes API by calling `POST /v1/account/agency/token` with your agency API key and an appointed agent email, as described in the [Rater Quotes API docs](https://api.steadily.com/quote-rater/redoc). Use the returned token in `Authorization: Bearer <token>` for quoting endpoints."
      },
      "steady_pat": {
        "type": "bearer",
        "label": "Steady personal access token",
        "generateUrl": "https://app.steady.space/my/integrations/edit",
        "setup": "Open your [personal connections page](https://app.steady.space/my/integrations/edit) and generate a personal access token, as described in the [API v2 announcement](https://runsteady.com/blog/steady-api-v2/). Use it as `Authorization: Bearer <your-token>`. The blog notes that read-only tokens can live forever, while tokens with write access expire within a year."
      },
      "steady_user_oauth": {
        "type": "oauth2",
        "label": "Steady user OAuth sign-in for MCP",
        "setup": "Connect from your MCP client to Steady's remote server URL and complete the browser-based OAuth 2.1 sign-in flow described in Steady's [MCP integration page](https://runsteady.com/integrations/mcp-server) and [MCP preview post](https://runsteady.com/blog/steady-mcp-server-preview/). Access is personally scoped to the authenticating user's Steady permissions."
      }
    },
