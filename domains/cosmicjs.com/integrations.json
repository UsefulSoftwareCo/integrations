    },
    {
      "authStatus": "required",
      "name": "Cosmic Dashboard API",
      "slug": "cosmic-dashboard-api",
      "type": "http",
      "url": "https://dapi.cosmicjs.com/v3"
    },
    {
      "authStatus": "unknown",
      "name": "Cosmic GraphQL API",
      "slug": "cosmic-graphql-api",
