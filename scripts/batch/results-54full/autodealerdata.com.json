    "summary": "autodealerdata.com exposes one documented REST/OpenAPI surface: the CIS Automotive API at https://api.autodealerdata.com/, authenticated either with direct-account `apiID`+`apiKey` on `/getToken` or with the resulting JWT on data endpoints.",
    "description": "AutoDealerData provides automotive market data, including vehicle sales, supply, pricing, listings, and dealership information across the U.S. Its product is sold as a subscription API with plan-based endpoint access and optional bulk/custom data offerings.",
    "credentials": {
      "cis_api_keys": {
        "type": "compound",
        "label": "CIS Automotive API key pair (`apiID` + `apiKey`)",
        "generateUrl": "https://autodealerdata.com/account",
        "setup": "Sign up or log in at [AutoDealerData](https://autodealerdata.com/signup), then open your [account page](https://autodealerdata.com/account) to retrieve your `API_ID` and `API_KEY`. These direct-account credentials are used to call `GET /getToken` on `https://api.autodealerdata.com/` and obtain a JWT. The docs explicitly say not to use RapidAPI keys on the direct API."
      },
      "cis_jwt": {
        "type": "jwt",
        "label": "CIS Automotive API JWT",
        "setup": "First get your direct-account `apiID` and `apiKey` from your [account page](https://autodealerdata.com/account). Then call `GET https://api.autodealerdata.com/getToken?apiID={API_ID}&apiKey={API_KEY}` (or the POST variant) to receive a JWT. The raw-requests guide says the token is valid for about 24 hours and must be refreshed by calling `/getToken` again."
      },
      "cis_subuser_key": {
        "type": "api_key",
        "label": "CIS Automotive sub-user API key",
        "generateUrl": "https://api.autodealerdata.com/docs",
        "setup": "Use your authenticated direct API account to create sub-user keys via the `POST /makeSubUserKey` endpoint documented in the [API docs](https://api.autodealerdata.com/docs). Pricing notes say plans include limited numbers of subuser API keys for frontend/client-side use. The public docs name the credential but do not clearly document exactly how it is presented on requests."
      }
