    "summary": "Uber Eats exposes a public no-auth MCP server and an OAuth-protected Uber Eats Marketplace HTTP API on `https://api.uber.com` for store, menu, order, reporting, promotions, and integration-activation workflows.",
    "description": "Uber Eats is Uber's food ordering and merchant marketplace platform. Its developer offering lets approved partners integrate merchant store operations, menus, and order workflows with Uber Eats.",
    "credentials": {
      "uber_client_credentials": {
        "type": "oauth2_cc",
        "label": "Uber developer app client credentials",
        "generateUrl": "https://developer.uber.com/dashboard",
        "setup": "Sign in to the [Uber Developer Dashboard](https://developer.uber.com/dashboard), create an application, and copy its `client_id` and `client_secret`. The Eats auth guide says to use these app credentials with the OAuth 2.0 `client_credentials` grant at `https://auth.uber.com/oauth/v2/token` for regular Store, Menu, Order, and Reporting API operations. Access to Eats scopes may require partner approval and written approval from Uber, as described in the [Getting Started guide](https://developer.uber.com/docs/eats/guides/getting-started) and [Authentication guide](https://developer.uber.com/docs/eats/guides/authentication)."
      },
      "uber_merchant_oauth": {
        "type": "oauth2",
        "label": "Uber merchant OAuth access token",
        "generateUrl": "https://developer.uber.com/dashboard",
        "setup": "First create an app in the [Uber Developer Dashboard](https://developer.uber.com/dashboard) to obtain your `client_id` and `client_secret`, then send merchants through Uber's OAuth consent flow using the authorization endpoint `https://auth.uber.com/oauth/v2/authorize` and exchange the code at `https://auth.uber.com/oauth/v2/token`. The Eats docs say this `authorization_code` token is required for store discovery and integration activation flows. See the [Authentication guide](https://developer.uber.com/docs/eats/guides/authentication) and [Integration Configuration Flows guide](https://developer.uber.com/docs/eats/guides/integration-activation-flows)."
      }
