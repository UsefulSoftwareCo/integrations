{
  "domain": "swell.is",
  "summary": "Swell exposes a REST Backend API, an experimental storefront GraphQL API, and the Swell CLI; auth is via store ID + secret key for the Backend API, a bearer-style secret key for GraphQL, and browser login for the CLI.",
  "surfaces": [
    {
      "authStatus": "required",
      "name": "Swell Backend API",
      "slug": "swell-backend-api",
      "type": "http",
      "url": "https://api.swell.store"
    },
    {
      "authStatus": "required",
      "name": "Swell Frontend GraphQL API",
      "slug": "swell-frontend-graphql-api",
      "type": "graphql",
      "url": "https://<your-store-id>.swell.store/graphql/v2"
    },
    {
      "authStatus": "required",
      "command": "swell",
      "name": "Swell CLI",
      "slug": "swell-cli",
      "type": "cli"
    }
  ]
}
