    "credentials": {
      "cosmic_bucket_keys": {
        "type": "compound",
        "label": "Cosmic bucket read/write keys",
        "generateUrl": "https://app.cosmicjs.com/login",
        "setup": "Go to [Cosmic dashboard](https://app.cosmicjs.com/login), open your bucket, then **Settings → API Access**. Copy the bucket slug, `read key`, and `write key`. The read key is used for read-only access; the write key enables writes. The same keys are also returned by the agent signup flow and can be reused in the SDK, REST API, and hosted MCP.",
        "acquisition": "manual"
      },
      "cosmic_pat": {
        "type": "bearer",
        "label": "Cosmic Personal Access Token",
        "generateUrl": "https://app.cosmicjs.com/account/api-tokens",
        "setup": "Open [Account Settings → API Tokens](https://app.cosmicjs.com/account/api-tokens) and create a new token. Cosmic PATs use the `cos_` prefix and carry full account permissions, so keep them secret. They are recommended for scripts, CI/CD, CLI login, dashboard API access, and MCP server use when bucket keys are not the right fit.",
        "acquisition": "manual"
      },
      "cosmic_agent_key": {
        "type": "bearer",
        "label": "Cosmic agent key",
        "generateUrl": "https://www.cosmicjs.com/docs/api/agents",
        "setup": "Use the agent signup flow to provision a project + bucket on behalf of a human. The response returns an `agent_key` with the `agk_` prefix. It is the bearer token for the agent-flow endpoints only (`/v3/agents/verify` and `/v3/agents/status`).",
        "acquisition": "manual"
      },
      "cosmic_cli_session": {
        "type": "bearer",
        "label": "Cosmic CLI login session",
        "generateUrl": "https://www.cosmicjs.com/docs/cli#authentication",
        "setup": "Run `cosmic login` to authenticate the CLI with your Cosmic account. For token-based login, run `cosmic login --token cos_YOUR_TOKEN` or set `COSMIC_TOKEN=cos_YOUR_TOKEN`. The CLI also supports `cosmic agent-signup` for no-prior-account agent provisioning, which stores the resulting session and keys locally.",
        "acquisition": "manual"
      }
    },
