{
  "domain": "novu.co",
  "summary": "Novu exposes a private REST API, a bearer-authenticated MCP server, a CLI sync command using the secret key, and a separate public docs MCP server.",
  "surfaces": [
    {
      "authStatus": "required",
      "name": "Novu REST API",
      "slug": "novu-rest-api",
      "type": "http",
      "url": "https://api.novu.co"
    },
    {
      "authStatus": "required",
      "name": "Novu MCP Server",
      "slug": "novu-mcp-server",
      "type": "mcp",
      "url": "https://mcp.novu.co/"
    },
    {
      "authStatus": "required",
      "command": "npx novu@latest sync",
      "name": "Novu CLI",
      "slug": "novu-cli",
      "type": "cli"
    },
    {
      "authStatus": "none",
      "name": "Novu documentation MCP server",
      "slug": "novu-documentation-mcp-server",
      "type": "mcp"
    }
  ]
}
