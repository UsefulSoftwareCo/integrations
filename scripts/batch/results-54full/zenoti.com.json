    "summary": "Zenoti exposes one documented REST API at https://api.zenoti.com with a curated OpenAPI spec; it supports either an API key or a bearer access token generated from app credentials plus user login.",
    "description": "Zenoti provides software for salons, spas, med spas, and similar wellness businesses to manage bookings, customers, employees, memberships, payments, and related operations. Its API documentation also covers webhooks and operational workflows built on the same core API.",
    "credentials": {
      "zenoti_api_key": {
        "type": "api_key",
        "label": "Zenoti API key",
        "generateUrl": "https://docs.zenoti.com/docs/create-the-backend-app-and-generate-a-new-api-key-1",
        "setup": "In Zenoti at the organization level, open [Create the backend app and generate a new API key](https://docs.zenoti.com/docs/create-the-backend-app-and-generate-a-new-api-key-1) or go to **Configuration** → **Apps** under **Integrations**. Add an app, choose its permissions and authentication method, copy the generated **Application ID** and **Secrets**, then click **Generate API Key** and copy the resulting API key. Zenoti recommends one API key per app/use case."
      },
      "zenoti_app_token_flow": {
        "type": "compound",
        "label": "Zenoti token-generation app credentials + user login",
        "generateUrl": "https://docs.zenoti.com/docs/create-the-backend-app-and-generate-a-new-api-key-1",
        "setup": "Create a backend app in [Create the backend app and generate a new API key](https://docs.zenoti.com/docs/create-the-backend-app-and-generate-a-new-api-key-1) or via **Configuration** → **Apps**. Copy the generated `app_id` and `app_secret`. To mint an access token, call [Generate an access token](https://docs.zenoti.com/reference/generate-an-access-token) with your Zenoti `account_name`, an app user's `user_name` and `password`, `grant_type`=`password`, the app's `app_id` and `app_secret`, and a `device_id`. The response returns a bearer `access_token` plus a `refresh_token` that can be rotated with [Refresh an access token](https://docs.zenoti.com/reference/refresh-an-access-token)."
      }
    },
