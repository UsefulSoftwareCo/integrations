    },
    {
      "authStatus": "required",
      "name": "PropelAuth OAuth2 endpoints",
      "slug": "propelauth-oauth2-endpoints",
      "type": "http",
      "url": "{AUTH_URL}/propelauth/oauth"
    },
    {
      "authStatus": "required",
      "name": "PropelAuth MCP authentication endpoints",
      "slug": "propelauth-mcp-authentication-endpoints",
      "type": "http",
      "url": "{AUTH_URL}/oauth/2.1"
    },
    {
      "authStatus": "required",
      "command": "propelauth",
      "name": "PropelAuth CLI",
      "slug": "propelauth-cli",
      "type": "cli"
    },
    {
      "authStatus": "unknown",
      "name": "PropelAuth MCP server",
      "slug": "propelauth-mcp-server",
      "type": "mcp",
      "url": "unknown"
    }
  ]
