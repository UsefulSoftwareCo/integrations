    "summary": "synq.fm exposes a legacy SYNQ Video HTTP API keyed by an `api_key`, plus current Coalesce Quality developer surfaces consisting of a gRPC API using client-credentials OAuth and a regional MCP server using OAuth2 PKCE or legacy bearer workspace tokens.",
    "description": "Synq provides Coalesce Quality, a data quality and observability platform for managing monitors, incidents, lineage, alerts, and related workflows across data systems. The synq.fm domain also has a published legacy SYNQ Video API for video creation, metadata, upload, and streaming operations.",
    "credentials": {
      "synq_video_api_key": {
        "type": "api_key",
        "label": "SYNQ Video API key",
        "generateUrl": "https://www.synq.fm/register",
        "setup": "Sign up for a developer API key via [SYNQ registration](https://www.synq.fm/register). The published OpenAPI description for SYNQ Video links to that signup page in its `info.description`. Use the issued key as the `api_key` form field when calling the Video API.",
        "acquisition": "manual"
      },
      "coalesce_api_client": {
        "type": "oauth2_cc",
        "label": "Coalesce Quality API client credentials",
        "generateUrl": "https://app.synq.io/settings/api",
        "setup": "In the [Coalesce Quality application API settings](https://app.synq.io/settings/api), create client credentials to obtain a `CLIENT_ID` and `CLIENT_SECRET`. The docs say these credentials are scoped, so choose the scope appropriate for the RPCs you plan to call. Exchange them with `grant_type=client_credentials` at `http://api.synq.io/oauth2/token` to obtain a bearer access token for the developer API.",
        "acquisition": "manual"
      },
      "coalesce_workspace_token": {
        "type": "bearer",
        "label": "Coalesce Quality workspace API token",
        "generateUrl": "https://app.synq.io/settings/api",
        "setup": "In the [Coalesce Quality application API settings](https://app.synq.io/settings/api), create a long-lived workspace token. The MCP docs describe these legacy static tokens as being prefixed `st-…`. Use the token as a `Bearer` token in the `Authorization` header when OAuth is not an option.",
        "acquisition": "manual"
      },
      "coalesce_user_oauth": {
        "type": "oauth2",
        "label": "Coalesce Quality user OAuth authorization",
        "setup": "Connect an MCP client to the regional MCP endpoint and let the client drive the browser-based OAuth2 with PKCE flow. The [MCP docs](https://docs.synq.io/scout/mcp.md) say the browser opens automatically, you log in if needed, choose a permission level, and approve access. Workspace admins can disable user API access in **Settings → Workspace**, in which case use a workspace token instead.",
        "acquisition": "manual"
      }
    },
