    "summary": "QuickBlox exposes a documented REST Server API at https://api.quickblox.com, authenticated either by `QB-Token` session tokens or server-side `ApiKey` authorization; no public GraphQL API, MCP server, or CLI surfaced in public docs.",
    "description": "QuickBlox provides chat, messaging, video calling, content storage, push notifications, custom objects, and related communication features for web and mobile applications. Its platform includes SDKs and UI kits for client apps plus a server-side HTTP API for backend integration.",
    "credentials": {
      "qb_api_key": {
        "type": "api_key",
        "label": "QuickBlox API key",
        "generateUrl": "https://docs.quickblox.com/docs/application#create-api-key",
        "setup": "In the [QuickBlox Application settings](https://docs.quickblox.com/docs/application), open **Dashboard => _YOUR_APP_ => General => API keys**, click **Add**, fill in the fields, and click **Create**. The API key is then used in the `Authorization` header as `ApiKey {your_api_key}`.",
        "acquisition": "manual"
      },
      "qb_app_credentials": {
        "type": "compound",
        "label": "QuickBlox application credentials (application ID, auth key, auth secret)",
        "generateUrl": "https://docs.quickblox.com/docs/application#get-application-credentials",
        "setup": "Create an app in the [QuickBlox Dashboard](https://docs.quickblox.com/docs/application#create-your-first-application), then open **Dashboard => _YOUR_APP_ => General => Overview** and copy the `Application ID`, `Authorization Key`, and `Authorization Secret`. Use them to sign `POST /session.json` requests as described in [Authentication](https://docs.quickblox.com/reference/authentication#signature-generation) and [Create Session](https://docs.quickblox.com/reference/create-session).",
        "acquisition": "manual"
      },
      "qb_session_token": {
        "type": "bearer",
        "label": "QuickBlox session token (QB-Token)",
        "generateUrl": "https://docs.quickblox.com/reference/create-session",
        "setup": "Mint a session token by calling [Create Session](https://docs.quickblox.com/reference/create-session) with your QuickBlox application credentials; for a user session include the user's login and password. The response returns a session `token`, which you send in the `QB-Token` header. Tokens are valid within the session and expire 2 hours after the last Server API request, per [Authentication](https://docs.quickblox.com/reference/authentication).",
        "acquisition": "manual"
      }
    },
