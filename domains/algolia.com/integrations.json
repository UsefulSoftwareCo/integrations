{
  "domain": "algolia.com",
  "summary": "Algolia exposes HTTP Search, Analytics, and Recommend APIs, two MCP surfaces (Productivity and Public), and an Algolia CLI; auth uses Algolia application ID plus API key for HTTP APIs, OAuth-backed MCP sign-in for Productivity MCP, and Search API key for Public MCP.",
  "surfaces": [
    {
      "authStatus": "required",
      "name": "Algolia Search API",
      "slug": "algolia-search-api",
      "type": "http",
      "url": "https://{APPLICATION_ID}.algolia.net"
    },
    {
      "authStatus": "required",
      "name": "Algolia Analytics API",
      "slug": "algolia-analytics-api",
      "type": "http",
      "url": "https://analytics.{region}.algolia.com/2"
    },
    {
      "authStatus": "required",
      "name": "Algolia Recommend API",
      "slug": "algolia-recommend-api",
      "type": "http",
      "url": "https://{APPLICATION_ID}.algolia.net/1"
    },
    {
      "authStatus": "required",
      "name": "Algolia Productivity MCP",
      "slug": "algolia-productivity-mcp",
      "type": "mcp",
      "url": "https://mcp.algolia.com/mcp"
    },
    {
      "authStatus": "required",
      "name": "Algolia Public MCP",
      "slug": "algolia-public-mcp",
      "type": "mcp",
      "url": "https://{APP_ID}.algolia.net/mcp/1/{UNIQ_ID}/mcp"
    },
    {
      "authStatus": "unknown",
      "command": "algolia",
      "name": "Algolia CLI",
      "slug": "algolia-cli",
      "type": "cli"
    }
  ]
}
