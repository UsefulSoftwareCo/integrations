{
  "domain": "cms.gov",
  "summary": "cms.gov exposes three developer surfaces: Marketplace API (API key via `apikey` query param), CMS Data API (public), Blue Button API v2 (OAuth-protected), and QPP Eligibility API (GraphQL with bearer JWT auth).",
  "surfaces": [
    {
      "authStatus": "required",
      "name": "QPP Eligibility API",
      "slug": "qpp-eligibility-api",
      "spec": "https://qpp.cms.gov/api/eligibility/spec/v6/",
      "type": "graphql",
      "url": "https://qpp.cms.gov/api/eligibility/"
    },
    {
      "authStatus": "required",
      "name": "CMS Marketplace API",
      "slug": "cms-marketplace-api",
      "type": "http",
      "url": "https://marketplace.api.healthcare.gov/api/v1"
    },
    {
      "authStatus": "none",
      "name": "CMS Data API",
      "slug": "cms-data-api",
      "type": "http",
      "url": "https://data.cms.gov/data-api/v1/dataset/{dataset_id}/data"
    },
    {
      "authStatus": "required",
      "name": "CMS Blue Button API v2",
      "slug": "cms-blue-button-api-v2",
      "type": "http",
      "url": "https://api.bluebutton.cms.gov/v2/fhir/"
    }
  ]
}
