    "summary": "Fun Translations exposes REST translation APIs (including a general API plus Braille and Star Wars subsets) and an HTTP MCP server; all documented integration surfaces use bearer-token authentication, with the MCP server also supporting x402-purchased time-scoped bearer tokens.",
    "description": "Fun Translations is an online text-translation service offering 150+ novelty, fictional-language, dialect, and encoding translators. It provides web-based translators and paid programmatic access for apps and AI agents.",
    "credentials": {
      "funtranslations_api_token": {
        "type": "bearer",
        "label": "Fun Translations API bearer token",
        "generateUrl": "https://funtranslations.com/api",
        "setup": "Create an account at [Register](https://funtranslations.com/register), then go to [API pricing and plans](https://funtranslations.com/api) and subscribe to a plan. The docs state your Bearer token appears in your dashboard immediately and is sent in the `Authorization: Bearer YOUR_API_KEY` header.",
        "acquisition": "manual"
      },
      "funtranslations_x402_token": {
        "type": "two_step",
        "label": "Fun Translations x402-issued bearer token",
        "generateUrl": "https://funtranslations.com/x402/plans",
        "setup": "For autonomous agents, discover plans at [GET /x402/plans](https://funtranslations.com/x402/plans), then POST to the listed purchase URL under `/x402/token/...`. The first POST returns `402 Payment Required` terms; after submitting the required `PAYMENT-SIGNATURE` payment proof, the service returns a time-scoped Bearer token plus the MCP endpoint. Use that token in `Authorization: Bearer ...` for the MCP server.",
        "acquisition": "manual"
      }
    },
