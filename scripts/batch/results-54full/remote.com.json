    "summary": "Remote exposes one authenticated REST API at `https://gateway.remote.com` plus a hosted MCP server at `https://mcp.remote.com/mcp`; the API supports customer bearer tokens and several partner OAuth-based modes, and the MCP server uses OAuth login with a Remote account.",
    "description": "Remote provides employer-of-record, payroll, HR, and workforce-management services for globally distributed teams. Its platform lets companies and employees manage employment, payroll, benefits, time off, expenses, and related HR data.",
    "credentials": {
      "customer_api_token": {
        "type": "bearer",
        "label": "Customer API token",
        "generateUrl": "https://developer.remote.com/docs/authorization-for-customers",
        "setup": "In the Remote dashboard, go to **Company → Company Settings → Integrations & APIs → Integrations**, open the **Remote API** card, and click **Generate API token**. Only company admins or company owners can create or revoke the token. See [Obtaining access token](https://developer.remote.com/docs/authorization-for-customers) and [Quick Start Guide for Customers](https://developer.remote.com/docs/quick-start-guide)."
      },
      "partner_client_credentials": {
        "type": "basic",
        "label": "Partner client ID and client secret",
        "generateUrl": "https://developer.remote.com/docs/getting-started-for-partners",
        "setup": "Become a Remote API partner, sign the NDA, and Remote sends your `CLIENT_ID` and `CLIENT_SECRET` in a 1Password share. Save them securely; the 1Password access is valid for 7 days. See [Quick Start Guide for Partners](https://developer.remote.com/docs/getting-started-for-partners)."
      },
      "partner_access_token": {
        "type": "oauth2_cc",
        "label": "Partner OAuth access token",
        "generateUrl": "https://developer.remote.com/docs/client-credentials-flow-for-partners",
        "setup": "Use your partner `CLIENT_ID` and `CLIENT_SECRET` to call `POST https://gateway.remote.com/auth/oauth2/token` (or sandbox `https://gateway.remote-sandbox.com/auth/oauth2/token`) with HTTP Basic auth and `grant_type=client_credentials`. Remote returns a bearer `access_token` valid for 3600 seconds. See [Client Credentials Flow for Partners](https://developer.remote.com/docs/client-credentials-flow-for-partners)."
      },
      "partner_refresh_token": {
        "type": "oauth2",
        "label": "Partner refresh token for company-authorized access",
        "generateUrl": "https://developer.remote.com/docs/authorization-code-flow",
        "setup": "Register as a Remote API partner and obtain `CLIENT_ID`/`CLIENT_SECRET`, then send a company admin through Remote's OAuth authorization-code consent flow. After approval, exchange the returned `code` at `POST https://gateway.remote.com/auth/oauth2/token` (or sandbox) using HTTP Basic auth to receive a `refresh_token`, which you can later exchange for bearer access tokens. See [Data sync for existing companies](https://developer.remote.com/docs/authorization-code-flow) and [Refresh Token Flow](https://developer.remote.com/docs/refresh-token-flow)."
      },
      "partner_oauth_assertion": {
        "type": "jwt",
        "label": "Partner-signed JWT assertion",
        "generateUrl": "https://developer.remote.com/docs/authorization-method-oauth-assertion",
        "setup": "Vetted partners create a JWT with `iss` set to their `CLIENT_ID`, `sub` bound to the Remote user or employment being acted for, `aud` matching Remote's auth server, and sign it with their partner `CLIENT_SECRET`. Exchange it at `POST /auth/oauth2/token` with `grant_type=urn:ietf:params:oauth:grant-type:jwt-bearer` to receive a bearer access token. See [Authorization Method — OAuth Assertion](https://developer.remote.com/docs/authorization-method-oauth-assertion)."
      },
      "remote_account_oauth": {
        "type": "oauth2",
        "label": "Remote account OAuth login for MCP",
        "generateUrl": "https://developer.remote.com/docs/introduction-to-remote-mcp",
        "setup": "Add the MCP server URL `https://mcp.remote.com/mcp` in an MCP-compatible client and sign in with your existing Remote account when the browser opens. The client dynamically registers and completes OAuth 2.0 Authorization Code with PKCE; no API key or client secret is created manually. See [Introduction to Remote.com MCP](https://developer.remote.com/docs/introduction-to-remote-mcp) and [Quick Start Guide](https://developer.remote.com/docs/quick-start-guide-2)."
      }
    },
