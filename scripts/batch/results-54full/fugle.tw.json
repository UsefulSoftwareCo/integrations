    "summary": "Fugle exposes a MarketData REST API, a real-time MarketData WebSocket API, an OAuth-protected MCP server at `/api/v2/mcp`, and a deprecated trading SDK/CLI flow for brokerage trading.",
    "description": "Fugle is a Taiwan-focused financial service offering stock market data APIs and brokerage trading tools. Its developer docs cover market data access, AI-agent MCP access, and a separate SDK-based trading integration tied to Esun/Fugle brokerage accounts.",
    "credentials": {
      "marketdata_api_key": {
        "type": "api_key",
        "label": "Fugle MarketData API key",
        "generateUrl": "https://developer.fugle.tw/docs/key/",
        "setup": "Go to [金鑰申請及管理](https://developer.fugle.tw/docs/key/) from the Fugle Developer Docs and create a key for the 行情 API (MarketData API). Use that key in requests as the `X-API-KEY` header, or send it in the WebSocket auth message as `apikey`.",
        "acquisition": "manual"
      },
      "fugle_oauth_app": {
        "type": "oauth2",
        "label": "Fugle OAuth client/application",
        "generateUrl": "https://www.fugle.tw/api/v2/oauth/register",
        "setup": "Register an OAuth client against Fugle's dynamic client registration endpoint at [OAuth client registration](https://www.fugle.tw/api/v2/oauth/register). Then run the OAuth authorization flow using [authorize](https://www.fugle.tw/api/v2/oauth/authorize) and exchange the code at [token](https://www.fugle.tw/api/v2/oauth/token). Available scopes include `note:read`, `note:write`, `watchlist:read`, `watchlist:write`, `data:read`, `price-alert:read`, and `price-alert:write`.",
        "acquisition": "manual"
      },
      "trading_api_bundle": {
        "type": "compound",
        "label": "Fugle Trading API config bundle",
        "generateUrl": "https://fugletradingapi.esunsec.com.tw/keys/Account/Logout",
        "setup": "Log in to the [交易 API 金鑰網站](https://fugletradingapi.esunsec.com.tw/keys/Account/Logout), apply for Trading API access, export your `.p12` certificate, download the simulation or production `config.ini`, and obtain the API `Key` and `Secret`. The SDK also prompts for your Esun/Fugle brokerage account password and certificate password at login. The config examples in the docs show `[Api] Key`, `[Api] Secret`, `[Cert] Path`, and `[User] Account`.",
        "acquisition": "manual"
      }
