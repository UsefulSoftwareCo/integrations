    "summary": "claude.com exposes Anthropic’s Claude developer surfaces: a REST Claude API at https://api.anthropic.com plus two CLIs (`ant` and `claude`), authenticated with Claude API keys and/or browser login sessions, with Workload Identity Federation also supported for the API and ant CLI.",
    "description": "Claude is Anthropic’s AI assistant and platform for accessing Claude models and managed agent infrastructure. It is available through web and desktop products as well as developer tools for programmatic use.",
    "credentials": {
      "claude_api_key": {
        "type": "api_key",
        "label": "Claude API key",
        "generateUrl": "https://platform.claude.com/settings/keys",
        "setup": "In the [Claude Console](https://platform.claude.com/), open [Settings → API keys](https://platform.claude.com/settings/keys) and create a key. Use [workspaces](https://platform.claude.com/settings/workspaces) to scope keys by project or environment. Send it in the `x-api-key` header for direct HTTP requests, or set `ANTHROPIC_API_KEY` for SDKs and supported CLIs.",
        "acquisition": "manual"
      },
      "claude_wif_token": {
        "type": "oauth2",
        "label": "Claude Workload Identity Federation access token",
        "generateUrl": "https://platform.claude.com/docs/en/manage-claude/workload-identity-federation",
        "setup": "Configure [Workload Identity Federation](https://platform.claude.com/docs/en/manage-claude/workload-identity-federation) in the Claude Console by creating a service account, federation issuer, and federation rule, then point your SDK or workload at the rule. Your workload exchanges its IdP-issued JWT at `POST /v1/oauth/token` for a short-lived Claude API access token and sends that token as `Authorization: Bearer <token>`. This is intended for production workloads and CI/CD rather than manual use.",
        "acquisition": "manual"
      },
      "ant_cli_login": {
        "type": "oauth2",
        "label": "ant CLI browser login session",
        "generateUrl": "https://platform.claude.com/docs/en/cli-sdks-libraries/cli/quickstart",
        "setup": "Install the `ant` CLI, then run `ant auth login`. It opens a browser-based OAuth flow against the Claude Console and stores the resulting credentials locally so the CLI can call the API without you creating an API key. See [CLI quickstart](https://platform.claude.com/docs/en/cli-sdks-libraries/cli/quickstart).",
        "acquisition": "manual"
      },
      "claude_code_login": {
        "type": "oauth2",
        "label": "Claude Code login session",
        "generateUrl": "https://code.claude.com/docs/en/authentication.md",
        "setup": "Install Claude Code, run `claude`, and complete the browser login flow on first launch. The docs say Claude Code opens a browser window for you to log in and stores credentials locally (`.credentials.json` on Linux/Windows, Keychain on macOS). You can re-authenticate with `/logout`. See [Authentication](https://code.claude.com/docs/en/authentication.md).",
        "acquisition": "manual"
      }
    },
