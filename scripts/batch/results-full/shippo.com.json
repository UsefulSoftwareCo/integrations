    "summary": "Shippo’s public developer surface includes the REST API, hosted/local MCP servers, and Shipping Elements; credentials are Shippo API tokens, OAuth bearer tokens, and short-lived Shipping Elements JWTs.",
    "credentials": {
      "shippo_api_token": {
        "type": "api_key",
        "label": "Shippo API token",
        "generateUrl": "https://portal.goshippo.com/api-config/api",
        "setup": "Log in to the [Shippo API portal](https://portal.goshippo.com/api-config/api), open **API Configuration** → **Developer keys**, and create either a **Live key** (`shippo_live_…`) or a **Test key** (`shippo_test_…`). Shippo shows the full token only once, so copy it immediately and store it securely. Use the test key while developing.",
        "acquisition": "manual"
      },
      "shippo_oauth_bearer_token": {
        "type": "oauth2",
        "label": "Shippo OAuth bearer token",
        "generateUrl": "https://goshippo.com/oauth/clients",
        "setup": "Create or register an OAuth client at [OAuth dynamic client registration](https://goshippo.com/oauth/clients), then complete the Shippo OAuth authorization flow to mint a bearer token for the signed-in Shippo account. Shippo’s OAuth endpoints are `https://goshippo.com/oauth/authorize` and `https://goshippo.com/oauth/access_token`; requested scopes are `*`. Use this when integrating as a third-party app or for the hosted MCP server.",
        "acquisition": "manual"
      },
      "shippo_jwt": {
        "type": "jwt",
        "label": "Shippo Shipping Elements JWT",
        "generateUrl": "https://docs.goshippo.com/docs/ShippingElements/auth",
        "setup": "For Shipping Elements, generate a short-lived JWT after first obtaining either a Shippo API token (white-label) or a Shippo OAuth bearer token (gray-label). In the white-label flow, first create or look up the managed Shippo account, then call `POST https://api.goshippo.com/embedded/authz/` with `Authorization: ShippoToken <API_TOKEN>` and `SHIPPO-ACCOUNT-ID: <shippo_account_id>`. In the gray-label flow, call the same endpoint with `Authorization: Bearer <OAUTH_BEARER_TOKEN>`. The JWT expires after about 12 hours and is used by the Shipping Elements client.",
        "acquisition": "manual"
      }
    },
