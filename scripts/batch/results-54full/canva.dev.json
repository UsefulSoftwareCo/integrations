    "summary": "Canva exposes REST HTTP APIs for Connect and SCIM, plus an npm-distributed CLI and a local stdio MCP server via the Canva CLI; Connect uses developer-created integration credentials, SCIM uses a team-generated bearer token, and the MCP server is documented as locally runnable without separate Canva auth.",
    "description": "Canva is a visual design platform with developer tooling for embedding Canva workflows, building Canva Apps, provisioning users, and exporting audit data for enterprise teams. Its developer docs on canva.dev cover Connect APIs, the Apps SDK, SCIM provisioning, audit logs setup, a CLI, and an MCP server.",
    "credentials": {
      "connect_oauth_client": {
        "type": "oauth2",
        "label": "Canva Connect integration OAuth client (client ID + client secret)",
        "generateUrl": "https://www.canva.com/developers/integrations",
        "setup": "In the [Canva Developer Portal](https://www.canva.com/developers/), open [Your integrations](https://www.canva.com/developers/integrations), click **Create an integration**, choose public or private, agree to the terms, then on **Configure your integration** copy the **Client ID** and click **Generate secret** to create a **Client secret**. Also add at least one authorized redirect URL on the integration's **Authentication** page and select the scopes your integration needs.",
        "acquisition": "manual"
      },
      "scim_bearer_token": {
        "type": "bearer",
        "label": "Canva SCIM access token",
        "generateUrl": "https://www.canva.com/settings/your-account",
        "setup": "Log in to your Canva account, open [Account settings](https://www.canva.com/settings/your-account), then under your team's settings open **SSO & provisioning**. Under **SCIM**, enable **Enable SCIM user provisioning** and copy the generated access token. Only team administrators and owners can generate it; toggling the setting revokes the previous token and creates a new one.",
        "acquisition": "manual"
      },
      "canva_cli_local_token": {
        "type": "bearer",
        "label": "Canva CLI locally stored auth token",
        "generateUrl": "https://www.canva.dev/docs/apps/canva-cli/",
        "setup": "Install `@canva/cli`, then run `canva login`. The CLI opens a browser access request page; approve access, copy the confirmation code back into the CLI, and the CLI stores an encrypted auth token locally in `~/.canva-cli/credentials` (or `%USERPROFILE%\\\\.canva-cli\\\\credentials` on Windows). Run `canva logout` to revoke and delete it.",
        "acquisition": "manual"
      }
    },
