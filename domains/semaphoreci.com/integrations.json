{
  "domain": "semaphoreci.com",
  "summary": "Semaphore exposes one public HTTP API, one hosted MCP server, and two CLIs (`sem` and `sem-ai`), all authenticated via Semaphore API token; hosted MCP also supports OAuth 2.1.",
  "surfaces": [
    {
      "authStatus": "required",
      "name": "Semaphore Public API",
      "slug": "semaphore-public-api",
      "type": "http",
      "url": "https://<organization-url>.semaphoreci.com/api/v1alpha"
    },
    {
      "authStatus": "required",
      "name": "Semaphore Hosted MCP Server",
      "slug": "semaphore-hosted-mcp-server",
      "type": "mcp",
      "url": "https://mcp.semaphoreci.com/mcp"
    },
    {
      "authStatus": "required",
      "command": "sem",
      "name": "sem CLI",
      "slug": "sem-cli",
      "type": "cli"
    },
    {
      "authStatus": "required",
      "command": "sem-ai",
      "name": "sem-ai CLI",
      "slug": "sem-ai-cli",
      "type": "cli"
    }
  ]
}
