{
  "domain": "weaviate.io",
  "summary": "Weaviate exposes a public REST API, a GraphQL/gRPC search API with auth unclear from docs, and a local Streamable HTTP MCP server that uses Bearer API keys when auth is enabled.",
  "surfaces": [
    {
      "authStatus": "none",
      "name": "Weaviate REST API",
      "slug": "weaviate-rest-api",
      "type": "http",
      "url": "https://{WEAVIATE_HOSTNAME}:{PORT}/v1"
    },
    {
      "authStatus": "unknown",
      "name": "Weaviate Search API (GraphQL/gRPC)",
      "slug": "weaviate-search-api-graphql-grpc",
      "type": "graphql",
      "url": "https://{WEAVIATE_HOSTNAME}:{PORT}/v1/graphql"
    },
    {
      "authStatus": "required",
      "name": "Weaviate MCP server",
      "slug": "weaviate-mcp-server",
      "type": "mcp",
      "url": "http://localhost:8080/v1/mcp"
    }
  ]
}
