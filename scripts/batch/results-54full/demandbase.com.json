        "label": "Demandbase API key set credentials (Client ID + Client Secret) for minting JWT access tokens",
        "generateUrl": "https://support.demandbase.com/hc/en-us/articles/38999526296603-Generate-and-Manage-API-Key-Sets",
        "setup": "In Demandbase One, go to [Generate and Manage API Key Sets](https://support.demandbase.com/hc/en-us/articles/38999526296603-Generate-and-Manage-API-Key-Sets) and follow **Settings > APIs > API Key Sets** to create a key set, choose API permissions, and create a token. Copy the generated `Client ID` and `Client Secret` immediately; the secret is only shown once. Use those values with the token endpoint shown in the [API reference](https://developer.demandbase.com/reference/generate_access_token) to generate a JWT bearer token for API calls.",
        "acquisition": "manual"
      },
      "db_api_jwt": {
        "type": "bearer",
        "label": "Demandbase JWT bearer access token for public APIs",
        "generateUrl": "https://developer.demandbase.com/reference/generate_access_token",
        "setup": "First create API credentials via [Generate and Manage API Key Sets](https://support.demandbase.com/hc/en-us/articles/38999526296603-Generate-and-Manage-API-Key-Sets). Then call the [Generate A JWT Token](https://developer.demandbase.com/reference/generate_access_token) endpoint at `https://uapi.demandbase.com/auth/v1/token`, passing `clientId` and `clientSecret`, to mint a JWT access token. Send the resulting token as `Authorization: Bearer <token>`. The support article notes the token is valid for 8 hours.",
        "acquisition": "manual"
      },
      "db_mcp_oauth": {
        "type": "oauth2",
        "label": "Demandbase MCP OAuth client registration and user-granted access token",
        "generateUrl": "https://developer.demandbase.com/docs/custom-mcp-clients",
        "setup": "Follow the [Custom MCP Clients quickstart](https://developer.demandbase.com/docs/custom-mcp-clients). You need Demandbase MCP enabled for your account, a user who can sign in to Demandbase, a hosted HTTPS redirect URI, and Demandbase Support to allowlist that exact redirect URI for your app ID. Discover OAuth metadata from the protected resource metadata at `https://gateway.demandbase.com/.well-known/oauth-protected-resource` and the advertised authorization server metadata (currently `https://gateway.demandbase.com/.well-known/oauth-authorization-server`). Register your client using the discovered `registration_endpoint`, then complete Authorization Code + PKCE to obtain an access token for the MCP server.",
        "acquisition": "manual"
