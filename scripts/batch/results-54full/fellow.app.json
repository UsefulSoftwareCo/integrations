    "summary": "Fellow exposes two developer integration surfaces on this domain: a tenant-scoped REST Developer API authenticated by Fellow API keys, and an OAuth-protected remote MCP server at `https://fellow.app/mcp` using dynamic OAuth discovery/registration.",
    "description": "Fellow is an AI meeting assistant and note-taking platform for recording, transcribing, summarizing, and organizing meeting content such as notes, action items, recordings, and calendar context. It also provides enterprise governance controls and integrations for meeting data access and automation.",
    "credentials": {
      "fellow_oauth": {
        "type": "oauth2",
        "label": "Fellow OAuth client / user authorization",
        "generateUrl": "https://fellow.app/mcp/register",
        "setup": "For an MCP client that supports dynamic client registration, register a client at [Fellow OAuth registration](https://fellow.app/mcp/register) or let the MCP client do discovery/registration automatically from the server metadata. Then send the user through [Authorize](https://fellow.app/mcp/authorize) to grant access, and exchange the code at [Token](https://fellow.app/mcp/token). Available scopes published by Fellow are `read_calendar`, `read_meeting_content`, `read_action_items`, `read_channels`, and `write_meeting_agenda`. The authorization server metadata says token endpoint auth supports `none`, `client_secret_post`, and `client_secret_basic`, with PKCE `S256`.",
        "acquisition": "manual"
      },
      "fellow_api_key": {
        "type": "api_key",
        "label": "Fellow Developer API key",
        "setup": "Have a workspace admin enable the Developer API in Fellow workspace security settings, then in Fellow go to **User Settings → API, MCP & Webhooks** (or **Developer tools**) and click **+ New API Key**. Name the key, copy it when shown, and store it securely; Fellow says it is only shown once. See [Developer API help](https://help.fellow.ai/en/articles/11817206-developer-api) and [API Authentication](https://developers.fellow.ai/reference/authentication-1).",
        "acquisition": "manual"
      }
