      "zitadel_service_account_token": {
        "type": "bearer",
        "label": "Service account access token",
        "setup": "In ZITADEL, create a [service account](https://zitadel.com/docs/guides/integrate/zitadel-apis/access-zitadel-apis) and grant it the needed admin permissions. Then authenticate it using one of the supported methods: private key JWT, client credentials, or a personal access token. For API access, request a token with scope `urn:zitadel:iam:org:project:id:zitadel:aud`, then send the resulting access token as `Authorization: Bearer <token>`.",
        "acquisition": "manual"
      },
      "zitadel_service_account_pat": {
        "type": "api_key",
        "label": "Service account personal access token (PAT)",
        "setup": "Create a PAT for a service account in ZITADEL from the management console or the Management API. The docs call out the `Create a Personal-Access-Token (PAT)` operation under the Management API. Use the resulting token directly when authenticating API calls.",
        "acquisition": "manual"
      },
      "zitadel_system_api_user_jwt": {
        "type": "jwt",
        "label": "System API user JWT",
        "setup": "For self-hosted ZITADEL only, define a System API user in runtime settings and upload its public key. Generate an RSA keypair, keep the private key locally, and sign a JWT with claims like `iss`, `sub`, `aud`, `iat`, and `exp`. You can also use `zitadel-tools key2jwt` to mint the JWT. The JWT is sent directly to the System API as `Authorization: Bearer <token>`.",
        "acquisition": "manual"
      }
    },
