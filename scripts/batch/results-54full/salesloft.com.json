      "salesloft_oauth_app": {
        "type": "oauth2",
        "label": "Salesloft OAuth app (authorization code)",
        "generateUrl": "https://accounts.salesloft.com/oauth/applications",
        "setup": "In [Salesloft Account](https://accounts.salesloft.com/oauth/applications), go to **Your Applications → OAuth Applications → Create New**. Create an app with grant type **Authorization Code**, set the redirect URI, choose scopes, then use the app's client ID and client secret to run Salesloft's OAuth 2.0 authorization-code flow. The docs show the authorization endpoint at `https://accounts.salesloft.com/oauth/authorize` and token endpoint at `https://accounts.salesloft.com/oauth/token`.",
        "acquisition": "manual"
      },
      "salesloft_oauth_cc_app": {
        "type": "oauth2_cc",
        "label": "Salesloft OAuth app (client credentials)",
