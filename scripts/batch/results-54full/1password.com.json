    "summary": "1Password exposes three developer surfaces—a hosted Events REST API (JWT bearer token), a self-hosted Connect Server REST API (Connect access token, with deployment via `1password-credentials.json`), a hosted Users API for Partners REST API (OAuth app client credentials exchanged for short-lived bearer tokens), plus the `op` CLI, which authenticates via a service account token or against Connect via `OP_CONNECT_HOST`/`OP_CONNECT_TOKEN`.",
    "credentials": {
      "events_bearer_token": {
        "type": "jwt",
        "label": "Events API bearer token",
        "generateUrl": "https://start.1password.com/developer-tools/active",
        "setup": "Create an Events Reporting integration in your 1Password account from the [Events API get started docs](https://www.1password.dev/events-api/get-started), then create a bearer token with the required event features from the [authorization guide](https://www.1password.dev/events-api/authorization). You can also provision it with the `op events-api` commands in the [CLI reference](https://www.1password.dev/cli/reference/management-commands/events-api). Save the token securely; it is sent as `Authorization: Bearer <token>`.",
        "acquisition": "manual"
      },
      "connect_access_token": {
        "type": "bearer",
        "label": "Connect server access token",
        "generateUrl": "https://start.1password.com/developer-tools/infrastructure-secrets/connect",
        "setup": "Create a Connect server workflow using the [Connect server setup guide](https://www.1password.dev/connect/get-started). During setup, 1Password issues an access token for applications to authenticate to the Connect REST API; additional tokens can be created later from the [manage Connect docs](https://www.1password.dev/connect/manage-connect#create-a-token). The same setup also generates a `1password-credentials.json` file used to deploy the server itself. Use the access token with the Connect API `Authorization: Bearer <token>` header, or set `OP_CONNECT_TOKEN` when using the CLI with Connect.",
        "acquisition": "manual"
      },
      "connect_credentials_file": {
        "type": "compound",
        "label": "Connect server deployment credentials file",
        "generateUrl": "https://start.1password.com/developer-tools/infrastructure-secrets/connect",
        "setup": "Create a Connect server workflow following the [Connect server get started guide](https://www.1password.dev/connect/get-started). 1Password generates a `1password-credentials.json` file containing the credentials required to deploy the Connect server containers. Mount this file for the server and point `OP_SESSION` at its path, or provide its base64-encoded contents as described in the [server configuration docs](https://www.1password.dev/connect/server-configuration).",
        "acquisition": "manual"
      },
      "service_account_token": {
        "type": "bearer",
        "label": "Service account token",
        "generateUrl": "https://start.1password.com/developer-tools/infrastructure-secrets/serviceaccount/?source=dev-portal",
        "setup": "Create a service account from the [service accounts get started guide](https://www.1password.dev/service-accounts/get-started) or with `op service-account create` from the [CLI reference](https://www.1password.dev/cli/reference/management-commands/service-account#service-account-create). Choose the vault and Environment access up front; those permissions are immutable. Save the token immediately because it is shown once, then provide it to tools as an environment variable for authentication (for example `OP_SERVICE_ACCOUNT_TOKEN`).",
        "acquisition": "manual"
      },
      "users_oauth_app": {
        "type": "oauth2_cc",
        "label": "Users API OAuth application client credentials",
        "generateUrl": "https://start.1password.com/integrations/directory",
        "setup": "Create an OAuth Application in your 1Password account using the [Users API get started guide](https://www.1password.dev/users-api/get-started) or the [OAuth authorization guide](https://www.1password.dev/users-api/authorization). In **Integrations** → **Directory**, select **OAuth Application**, configure the redirect URL and required scopes, then select **Generate credentials**. Save the client ID and client secret immediately; the secret is shown once. Use them with HTTP Basic auth to request short-lived access tokens from the OAuth token endpoint.",
        "acquisition": "manual"
      },
      "users_access_token": {
        "type": "bearer",
        "label": "Users API OAuth access token",
        "generateUrl": "https://api.1password.com/v1beta1/users/oauth2/token",
        "setup": "First create a 1Password-issued OAuth application as described in the [Users API get started guide](https://www.1password.dev/users-api/get-started). Then request an access token from the regional token endpoint described in the [request access token docs](https://www.1password.dev/users-api/request-access-token) by sending the client ID and client secret with HTTP Basic auth and `grant_type=client_credentials`. The returned bearer token lasts 15 minutes and is used in `Authorization: Bearer <token>` when calling the Users API.",
        "acquisition": "manual"
      }
    },
