    "summary": "Directus exposes a REST API, GraphQL API, and a remote MCP server; authenticate the APIs with a Directus static access token as `Authorization: Bearer <token>`, and authenticate MCP either via MCP OAuth at `https://your-directus-url.com/mcp` or with a static token as `?access_token=<token>`.",
    "credentials": {
      "directus_static_token": {
        "type": "bearer",
        "label": "Directus static access token",
        "generateUrl": "https://directus.com/docs/guides/auth/tokens-cookies",
        "setup": "In Directus, open **User Directory** and select the user you want to act as. On the user page, generate a **static token** in the **Token** field, copy it, and save the user. Directus notes this token does not expire. Use it as `Authorization: Bearer <token>` or, for MCP local setups, in `DIRECTUS_TOKEN`.",
        "acquisition": "manual"
      },
      "directus_oauth_mcp": {
        "type": "oauth2",
        "label": "Directus MCP OAuth token",
        "generateUrl": "https://directus.com/docs/guides/ai/mcp/oauth",
        "setup": "Enable MCP OAuth in Directus settings and the corresponding environment variables for your instance. For self-hosted projects, set `MCP_OAUTH_ENABLED=true` and enable either `MCP_OAUTH_CIMD_ENABLED=true` or `MCP_OAUTH_DCR_ENABLED=true` (or both), then restart Directus. Compatible MCP clients connect to `https://your-directus-url.com/mcp` and complete the browser consent flow; Directus issues a bearer token scoped to the MCP endpoint with `mcp:access`.",
        "acquisition": "manual"
      },
      "directus_mcp_client_secret": {
        "type": "oauth2_cc",
        "label": "Directus MCP OAuth client secret",
        "generateUrl": "https://directus.com/docs/guides/ai/mcp/oauth",
        "setup": "When using Directus MCP OAuth with Dynamic Client Registration, the client may be registered as confidential and receive a `client_secret` once in the registration response. This secret is used at the token and revocation endpoints with `client_secret_basic` or `client_secret_post`.",
        "acquisition": "manual"
      }
