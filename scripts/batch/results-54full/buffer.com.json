    "summary": "Buffer exposes a public GraphQL API at `https://api.buffer.com` plus an npm-distributed `buffer` CLI; both use Buffer-issued credentials, with the API supporting personal bearer API keys and documented OAuth 2.0 app access.",
    "description": "Buffer is a social media publishing and management platform for scheduling posts, managing channels, and organizing content ideas across connected social accounts. It lets users and teams manage social content and related workflows from one place.",
    "credentials": {
      "buffer_api_key": {
        "type": "bearer",
        "label": "Buffer personal API key",
        "generateUrl": "https://publish.buffer.com/settings/api",
        "setup": "Log in to your [Buffer account](https://buffer.com), then open [Settings → API](https://publish.buffer.com/settings/api). Under **Personal Keys**, click **+ New Key**, choose the permission scopes and expiration, generate the key, and copy it. Buffer docs say to send it as `Authorization: Bearer YOUR_TOKEN`."
      },
      "buffer_oauth_app": {
        "type": "oauth2",
        "label": "Buffer OAuth client (Authorization Code + PKCE)",
        "generateUrl": "https://publish.buffer.com/settings/api",
        "setup": "Log in to [Buffer](https://buffer.com) and open [Settings → API](https://publish.buffer.com/settings/api) to register your app. Register a redirect URI. Confidential clients receive a `client_id` and `client_secret`; public clients receive a `client_id` and use PKCE without a secret. Buffer's docs state OAuth uses the Authorization Code flow with PKCE for all clients."
      }
