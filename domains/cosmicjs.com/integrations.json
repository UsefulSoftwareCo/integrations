{
  "domain": "cosmicjs.com",
  "summary": "Cosmic exposes REST and Dashboard HTTP APIs, a GraphQL API, a hosted/self-hosted MCP server, and the `cosmic` CLI; auth uses bucket read/write keys, PATs, agent keys, and CLI login/token sessions.",
