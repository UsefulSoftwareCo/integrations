    "summary": "Zillow exposes a public no-auth MCP server at https://mcp.zillow.com/api/v1 plus several partner HTTP APIs, authenticated either with a Zillow mortgage `partnerId`, Bridge Interactive access token/password credentials for Bridge-backed data APIs, dotloop OAuth 2.0 for transaction management, or Mortech-issued third-party-name/license-key credentials where Zillow documents them.",
    "credentials": {
      "zillow_partner_id": {
        "type": "api_key",
        "label": "Zillow mortgage partner ID",
        "generateUrl": "https://www.zillowgroup.com/developers/api/mortgage/get-current-rates/",
        "setup": "Go to Zillow Group's [Get Current Rates API page](https://www.zillowgroup.com/developers/api/mortgage/get-current-rates/) or the [Mortgage Partner APIs page](https://www.zillow.com/mortgage/api/) and use **Request Access / Request Partner ID**. Zillow states you'll need a partner ID first, and the API docs describe `partnerId` values like `RD-EXAMPLE` passed on each call.",
        "acquisition": "manual"
      },
      "bridge_api_token": {
        "type": "api_key",
        "label": "Bridge Interactive API access token",
        "generateUrl": "https://bridgedataoutput.com/register",
        "setup": "Create an account on the [Bridge Interactive Platform](https://bridgedataoutput.com/register), then request the relevant Zillow Group dataset from the Bridge dashboard as Zillow's docs describe: `API Access > Request Data Access > Zillow Group Datasets > Agree to the Zillow Data Terms of Use > Locate the dataset > Click Apply`. Zillow says your access tokens are available on the Bridge dashboard under `Data Access > API Access Tokens`.",
        "acquisition": "manual"
      },
      "bridge_password": {
        "type": "basic",
        "label": "Bridge Interactive account password",
        "generateUrl": "https://bridgedataoutput.com/register",
        "setup": "Register on the [Bridge Interactive Platform](https://bridgedataoutput.com/register) and complete dataset approval for the Zillow/Bridge data you need. Zillow's API directory says several Bridge-backed Zillow datasets use 'Password and access token authentication', so your Bridge account password is one part of that login.",
        "acquisition": "manual"
      },
      "dotloop_oauth_app": {
        "type": "oauth2",
        "label": "dotloop OAuth app",
        "generateUrl": "https://www.zillowgroup.com/developers/api/transactions/transaction-management/",
        "setup": "Request access from Zillow via the [Transaction Management API page](https://www.zillowgroup.com/developers/api/transactions/transaction-management/). That page points developers to the [dotloop Public API guide](https://dotloop.github.io/public-api/), which says Public API v2 uses OAuth 2.0 (3-legged OAuth) and requires client registration for your application.",
        "acquisition": "manual"
      },
      "mortech_license": {
        "type": "compound",
        "label": "Mortech third-party name and license key",
        "generateUrl": "https://www.zillowgroup.com/developers/api/mortgage/prospect-sync-api/",
        "setup": "Use the relevant Zillow mortgage partner API request form, such as [Prospect Sync API](https://www.zillowgroup.com/developers/api/mortgage/prospect-sync-api/), [Prospect Trigger API](https://www.zillowgroup.com/developers/api/mortgage/prospect-trigger-api/), [Rate Cloud API](https://www.zillowgroup.com/developers/api/mortgage/rate-cloud-api/), [LOS Plug-In Integration API](https://www.zillowgroup.com/developers/api/mortgage/los-plug-in-integration-api/), or [Lead Posting API](https://www.zillowgroup.com/developers/api/mortgage/lead-posting-api/). Zillow documents the authentication model for these as `Third Party Name, License Key`; the exact issuance and transport mechanics are not publicly documented on the pages scraped.",
        "acquisition": "manual"
      }
    },
