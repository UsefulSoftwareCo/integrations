        "type": "compound",
        "label": "Cosmic bucket read key + write key",
        "setup": "Go to [Cosmic dashboard](https://app.cosmicjs.com/login) and open your bucket. In **Settings → API Access**, copy the bucket slug, read key, and write key. The read key is used for content reads; the write key is used for authenticated writes. Cosmic also returns the same bucket keys from the agent signup flow, and they can be pasted into SDK, REST, CLI, or MCP configs.",
        "acquisition": "manual"
      },
      "cosmic_pat": {
        "type": "bearer",
        "label": "Cosmic Personal Access Token (PAT)",
        "generateUrl": "https://app.cosmicjs.com/account/api-tokens",
        "setup": "Open [Account Settings → API Tokens](https://app.cosmicjs.com/account/api-tokens) in the Cosmic dashboard and create a new token. Tokens use the `cos_` prefix and are the recommended credential for dashboard-level API access, scripts, CI/CD, and automation. Copy it once and store it securely; never expose it in client-side code.",
        "acquisition": "manual"
      },
      "cosmic_agent_key": {
        "type": "bearer",
        "label": "Cosmic agent key",
        "generateUrl": "https://dapi.cosmicjs.com/v3/agents/sign-up",
        "setup": "Use the agent signup flow to provision a project and bucket on behalf of a human. The easiest path is the CLI `cosmic agent-signup --email you@example.com --project \"Project Name\" --agent-id your-agent`, or call `POST https://dapi.cosmicjs.com/v3/agents/sign-up` directly. This returns an `agk_...` agent key, the bucket keys, and a claim URL/OTP flow. Keep the agent key private; it authorizes the verify/status endpoints for that signup session.",
        "acquisition": "manual"
      }
