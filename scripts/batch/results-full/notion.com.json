        "setup": "Create an [Internal connection](https://app.notion.com/developers/connections) in the Developer portal as a workspace owner, then open the connection’s **Configuration** tab to copy the **Installation access token**. Share the required pages or databases with the connection from the **Content access** tab or from the Notion UI via **Connections → Add connections**.",
        "acquisition": "manual"
      },
      "notion_oauth_token": {
        "type": "oauth2",
