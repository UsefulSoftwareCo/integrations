    "summary": "fire.com exposes two documented HTTP APIs: the Fire Financial Services Business API for business-account operations and a dedicated Open Banking TPP API at dia-api.fire.com; both require authentication and no GraphQL, MCP, or CLI surface was found.",
    "description": "Fire Financial Services provides business payment accounts and related services including bank transfers, debit cards, FX, and open banking payments. Its products let businesses automate payments, reconciliation, and account-based payment acceptance.",
    "credentials": {
      "fire_app_tokens": {
        "type": "compound",
        "label": "Fire API application tokens (Client ID, Client Key, Refresh Token)",
        "generateUrl": "https://business.fire.com",
        "setup": "Sign in to [Fire Business](https://business.fire.com), open **Settings → API**, click **Add New Application**, choose the required permissions, and create the app. Fire then shows three values you must save: `Client ID`, `Client Key`, and `Refresh Token`; the `Client Key` is only shown once. Use these to mint short-lived bearer access tokens as described in the [Authentication guide](https://docs.fire.com/docs/authentication).",
        "acquisition": "manual"
      },
      "fire_tpp_client_cert": {
        "type": "compound",
        "label": "Fire TPP dynamic client registration + mutual-TLS client authentication",
        "generateUrl": "https://dia-api.fire.com/tpp/register",
        "setup": "For Fire's dedicated Open Banking API, register a TPP application using dynamic client registration at [TPP API documentation](https://www.fire.com/the-fire-api/tpp-api-documentation/). Fire supports DCR at [`https://dia-api.fire.com/tpp/register`](https://dia-api.fire.com/tpp/register) and uses `tls_client_auth`; the certificate must match the `tls_client_auth_dn` in your registration request and be present in your JWKS. The OpenID configuration is published at [dia.fire.com generic discovery](https://dia.fire.com/.well-known/openid-configuration), with business and personal variants also documented.",
        "acquisition": "manual"
      }
    },
