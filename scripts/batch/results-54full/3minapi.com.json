    "summary": "3minapi.com exposes a REST data API at `https://api.3minapi.com/api/v1/data/{slug}` authenticated with bearer endpoint keys, plus an MCP server at `https://3minapi.com/api/mcp` that supports either OAuth account login or an `x-api-key` MCP key for CLI/IDE tools.",
    "description": "3Min API is a no-code service for creating and hosting CRUD-style JSON endpoints without building a backend. It lets users define schemas, test in sandbox, invite collaborators, and manage API activity through a web dashboard.",
    "credentials": {
      "endpoint_api_key": {
        "type": "bearer",
        "label": "Endpoint API key",
        "setup": "Create an endpoint in the [dashboard](https://3minapi.com/auth). 3Min API automatically issues environment-specific endpoint keys for that endpoint: a sandbox key prefixed `tm_test_` when the endpoint is created, and a production key prefixed `tm_live_` after deployment. Owners can view/regenerate them on the endpoint detail page; collaborators can access their own invited keys from their dashboard.",
        "acquisition": "manual"
      },
      "mcp_api_key": {
        "type": "api_key",
        "label": "MCP API key",
        "generateUrl": "https://3minapi.com/auth",
        "setup": "Sign in to the [3Min API dashboard](https://3minapi.com/auth), then go to Settings → AI Integration → CLI / IDE and click `Generate MCP API Key`. Copy the one-time-shown key prefixed `tm_mcp_` immediately; if lost, regenerate it from the same screen, which invalidates the old key.",
        "acquisition": "manual"
      },
