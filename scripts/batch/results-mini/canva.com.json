        "label": "Canva OAuth client credentials (Basic auth)",
        "generateUrl": "https://www.canva.com/developers/integrations",
        "setup": "Use the `Client ID` and `Client secret` from your Canva integration in the [Developer Portal](https://www.canva.com/developers/integrations). For token and revoke requests, encode `client_id:client_secret` as HTTP Basic credentials and send it in `Authorization: Basic ...` on the `/rest/v1/oauth/token` and `/rest/v1/oauth/revoke` endpoints. Canva recommends Basic auth over putting `client_id` and `client_secret` in the body.",
        "acquisition": "manual"
