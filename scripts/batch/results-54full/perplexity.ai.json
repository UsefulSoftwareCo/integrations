    "summary": "Perplexity exposes authenticated HTTP APIs at api.perplexity.ai (Agent, Search, Sonar, Embeddings, model listing, and auth-token management under one API platform), a separate bearer-authenticated Computer Analytics HTTP API, and an MCP server at https://www.perplexity.ai/rest/computer/mcp with published OAuth metadata; it also ships an npm-based MCP server CLI package.",
    "description": "Perplexity provides web-grounded AI and search products, including APIs for search, chat/reasoning, agents, embeddings, and enterprise computer-usage analytics. It also offers an MCP integration so AI assistants can access Perplexity capabilities through the Model Context Protocol.",
    "credentials": {
      "pplx_api_key": {
        "type": "bearer",
        "label": "Perplexity API key",
        "generateUrl": "https://console.perplexity.ai",
        "setup": "Go to the [Perplexity API console](https://console.perplexity.ai). Create an API group first if prompted, then open the API Keys area and generate a new key. The docs note the full key is shown only once, so copy and store it securely. You can also create additional keys programmatically after you have one, via the auth-token management endpoints described in [API Key Management](https://docs.perplexity.ai/docs/admin/api-key-management).",
        "acquisition": "manual"
      },
      "pplx_analytics_key": {
        "type": "bearer",
        "label": "Perplexity Computer Analytics API key",
        "generateUrl": "https://www.perplexity.ai",
        "setup": "In the Perplexity web app, an org admin opens the organization's Computer settings, finds the Analytics section, enables `Analytics API`, then selects `Generate key`. This key is org-scoped, analytics-only, and there is at most one active key at a time, per [Computer Analytics API](https://docs.perplexity.ai/docs/admin/computer-analytics-api).",
        "acquisition": "manual"
      },
      "pplx_mcp_oauth_client": {
        "type": "oauth2",
        "label": "Perplexity MCP OAuth client",
        "generateUrl": "https://www.perplexity.ai/rest/computer/mcp/register",
        "setup": "Register an OAuth client against Perplexity's MCP authorization server using the dynamic client registration endpoint `https://www.perplexity.ai/rest/computer/mcp/register`, then run the authorization-code flow against the Perplexity MCP issuer. The published OAuth metadata at [authorization server metadata](https://www.perplexity.ai/rest/computer/mcp/.well-known/oauth-authorization-server) shows authorization endpoint `https://www.perplexity.ai/rest/computer/mcp/authorize`, token endpoint `https://www.perplexity.ai/rest/computer/mcp/token`, registration endpoint `https://www.perplexity.ai/rest/computer/mcp/register`, and supported scope `asi:query`.",
        "acquisition": "manual"
      }
