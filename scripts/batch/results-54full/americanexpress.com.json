    "summary": "American Express exposes a developer portal for multiple APIs with shared auth patterns (client ID/secret, OAuth 2.0, HMAC, and sometimes mTLS), plus a known Resy MCP endpoint at `https://apigw.americanexpress.com/dining/v1/mcp`; no public GraphQL API or CLI was found.",
    "description": "American Express is a financial services company that offers card, payments, rewards, travel, and business products. Its developer program provides API access for selected American Express and partner-facing use cases through the American Express Developers portal.",
    "credentials": {
      "amex_client_credentials": {
        "type": "compound",
        "label": "American Express Client ID and Client Secret",
        "generateUrl": "https://developer.americanexpress.com/signup",
        "setup": "Create an account in the [American Express Developers Portal](https://developer.americanexpress.com/signup), create a Project, request the API product you need, and complete any required to-do items. The Project dashboard shows your `Client ID` and `Client Secret` after access is approved. Some products also require certificate upload and contract approval before credentials are issued, as described in [Getting Started](https://developer.americanexpress.com/documentation/getting-started) and [Documentation](https://developer.americanexpress.com/documentation)."
      },
      "amex_oauth2_token": {
        "type": "oauth2_cc",
        "label": "American Express OAuth 2.0 access token",
        "generateUrl": "https://developer.americanexpress.com/signup",
        "setup": "First obtain a `Client ID` and `Client Secret` from your Project in the [American Express Developers Portal](https://developer.americanexpress.com/signup). For 2-legged OAuth, generate a client assertion JWT signed with your client secret and exchange it for an access token using the OAuth resource URL shown in your Project dashboard; for 3-legged OAuth, register your brand assets and redirect URL, then complete the consent flow and exchange the authorization code for a token. Use the returned token as `Authorization: Bearer ...`. See [OAuth 2.0](https://developer.americanexpress.com/documentation/api-security/oauth-2), [OAuth 2-Legged](https://developer.americanexpress.com/documentation/api-security/oauth-client-credentials-flow), and [OAuth 3-Legged](https://developer.americanexpress.com/documentation/api-security/oauth-authorization-code-flow)."
      },
      "amex_client_certificate": {
        "type": "app",
        "label": "Uploaded client certificate for mTLS",
        "generateUrl": "https://developer.americanexpress.com/documentation/api-security/certificates",
        "setup": "Obtain a certificate from a trusted certificate authority, format it as a full-chain `.PEM`, then upload it in your Project in the [American Express Developers Portal](https://developer.americanexpress.com/). American Express documents separate Sandbox and Production certificate setup and says some API products require certificate upload before access is granted. Follow [Certificates](https://developer.americanexpress.com/documentation/api-security/certificates) and the project to-do items in [Getting Started](https://developer.americanexpress.com/documentation/getting-started)."
      },
      "amex_hmac_keypair": {
        "type": "signature",
        "label": "American Express HMAC client credentials",
        "generateUrl": "https://developer.americanexpress.com/signup",
        "setup": "Create a Project in the [American Express Developers Portal](https://developer.americanexpress.com/signup) and obtain the `Client ID` and `Client Secret` from the Project dashboard after approval. For HMAC-protected APIs, use the client ID as the MAC id and the client secret to compute the `Authorization: MAC ...` signature as described in [HMAC](https://developer.americanexpress.com/documentation/api-security/hmac)."
      }
