    "summary": "Quicknode exposes HTTP APIs for agent subscriptions/payments, admin operations, Streams, and Webhooks, plus a hosted OAuth MCP server and a local `@quicknode/mcp` CLI/server package.",
    "description": "Quicknode provides blockchain infrastructure including RPC endpoints, real-time data streaming, webhooks, and management APIs across many chains and networks. It also offers AI-oriented access patterns such as wallet-paid agent APIs and an MCP server for managing Quicknode infrastructure.",
    "credentials": {
      "qn_api_key": {
        "type": "api_key",
        "label": "Quicknode API key (QN_*)",
        "generateUrl": "https://dashboard.quicknode.com/api-keys",
        "setup": "Create a Quicknode account at [Sign up](https://www.quicknode.com/signup), then generate or manage an API key in the [Quicknode dashboard API Keys page](https://dashboard.quicknode.com/api-keys). Agents can also obtain a one-time `QN_*` key programmatically via the [Agent Subscription API guide](https://www.quicknode.com/agents/create-endpoint.md)."
      },
      "x402_wallet_payment": {
        "type": "signature",
        "label": "x402 wallet-based payment/auth",
        "generateUrl": "https://www.quicknode.com/docs/build-with-ai/x402-payments",
        "setup": "Use a funded wallet and the x402 flow described in [x402 Payments](https://www.quicknode.com/docs/build-with-ai/x402-payments). Quicknode documents that agents sign a SIWE/SIWX message, receive a JWT, and pay by attaching the x402 payment header on each request; the easiest path is to use the [`@quicknode/x402` SDK](https://www.quicknode.com/agents.md)."
      },
      "mpp_payment": {
        "type": "signature",
        "label": "MPP wallet-based payment credential",
        "generateUrl": "https://www.quicknode.com/docs/build-with-ai/mpp-payments",
        "setup": "Use the Machine Payments Protocol flow from [MPP Payments](https://www.quicknode.com/docs/build-with-ai/mpp-payments). Quicknode recommends the `mppx` client so requests automatically handle the HTTP `402` payment challenge and send `Authorization: Payment ...` credentials to `https://mpp.quicknode.com`."
      },
      "qn_oauth": {
        "type": "oauth2",
        "label": "Quicknode account OAuth authorization",
        "generateUrl": "https://www.quicknode.com/signup",
        "setup": "Create a Quicknode account at [Sign up](https://www.quicknode.com/signup), then connect from an MCP client such as Claude, ChatGPT, Codex, Cursor, or VS Code as described in [Quicknode MCP](https://www.quicknode.com/docs/build-with-ai/quicknode-mcp). On first connection, the MCP client opens a browser to log in to Quicknode and approve access."
      }
    },
