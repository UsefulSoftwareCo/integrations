    "summary": "Mapped Chargebee’s public developer surface: REST APIs (v1 and v2) authenticated with site API keys via HTTP Basic auth, plus four MCP server surfaces (knowledge-base public; data-lookup, onboarding, and custom servers using per-server bearer API keys or Chargebee-issued OAuth clients).",
    "credentials": {
      "cb_api_key": {
        "type": "basic",
        "label": "Chargebee API key for REST API",
        "generateUrl": "https://app.chargebee.com/login",
        "setup": "Log in to [Chargebee Billing](https://app.chargebee.com/login), then go to **Settings → Configure Chargebee → API Keys and Webhooks → API Keys**. Click **Add an API Key**, choose a **Full-Access Key**, name it, and copy the key. Use the test-site key for development and the live-site key for production. Send it with HTTP Basic auth as the username and an empty password (`Authorization: Basic base64(api_key:)`)."
      },
      "cb_mcp_api_key": {
        "type": "bearer",
        "label": "Chargebee MCP server API key",
        "generateUrl": "https://app.chargebee.com",
        "setup": "Log in to [Chargebee Billing](https://app.chargebee.com), go to **Settings → Configure Chargebee → Agentic AI → MCP Servers**, open the target MCP server (predefined or custom), then in **Access & Authentication** enable **MCP Access** and create an **API Key** for that server. Chargebee allows up to 5 API keys per MCP server. Send it as `Authorization: Bearer YOUR-API-KEY`."
      },
      "cb_mcp_oauth_client": {
        "type": "oauth2",
        "label": "Chargebee MCP OAuth client",
        "generateUrl": "https://app.chargebee.com",
        "setup": "Log in to [Chargebee Billing](https://app.chargebee.com), go to **Settings → Configure Chargebee → Agentic AI → MCP Servers**, open the target MCP server (predefined or custom), then in **Access & Authentication** enable **MCP Access** and configure **OAuth** for that server. Chargebee says you can generate one OAuth client ID per MCP client and share it across that client's users; users are then redirected to the Chargebee Billing login page and their tool access is limited by their Chargebee user access level. OAuth is not supported on sites with Multi-Business Entity enabled; use an MCP API key instead."
      }
    },
