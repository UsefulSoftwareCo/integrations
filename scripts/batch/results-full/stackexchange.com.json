        "acquisition": "manual"
      },
      "se_access_token": {
        "type": "bearer",
        "label": "Stack Exchange OAuth access token",
        "generateUrl": "https://stackapps.com/apps/oauth/register",
        "setup": "Authorize your Stack Apps application with the Stack Exchange OAuth flow to mint an `access_token`. For server-side apps, use the authorization code grant (recommended with PKCE where applicable). For client-side apps, use the implicit flow. If you need a long-lived token, request the `no_expiry` scope, though Stack Exchange advises against it unless truly necessary.",
        "acquisition": "manual"
      }
