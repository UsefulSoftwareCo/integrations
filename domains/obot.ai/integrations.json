{
  "domain": "obot.ai",
  "summary": "Obot exposes an authenticated HTTP API, authenticated OpenAI/Anthropic LLM gateway endpoints, a public MCP registry API, and authenticated MCP server connect endpoints, all using Obot API keys.",
  "surfaces": [
    {
      "authStatus": "required",
      "name": "Obot API",
      "slug": "obot-api",
      "type": "http",
      "url": "https://<obot-host>"
    },
    {
      "authStatus": "required",
      "name": "Obot LLM Gateway - OpenAI",
      "slug": "obot-llm-gateway-openai",
      "type": "http",
      "url": "https://<your-obot-host>/api/llm-proxy/openai"
    },
    {
      "authStatus": "required",
      "name": "Obot LLM Gateway - Anthropic",
      "slug": "obot-llm-gateway-anthropic",
      "type": "http",
      "url": "https://<your-obot-host>/api/llm-proxy/anthropic"
    },
    {
      "authStatus": "none",
      "name": "Obot MCP Registry API",
      "slug": "obot-mcp-registry-api",
      "type": "http",
      "url": "https://<obot-host>/v0.1/servers"
    },
    {
      "authStatus": "required",
      "name": "Obot MCP server connect endpoint",
      "slug": "obot-mcp-server-connect-endpoint",
      "type": "mcp",
      "url": "https://<obot-host>/mcp-connect/<server-name>/mcp"
    }
  ]
}
