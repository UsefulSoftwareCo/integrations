    "summary": "Mapped 2 HTTP APIs for api.video: the main REST API at https://ws.api.video (OpenAPI YAML plus APIs.guru JSON alternate; Basic auth with project API key or bearer token) and the Admin API at https://admin.api.video (Basic auth with support-issued admin API key).",
    "credentials": {
      "project_api_key": {
        "type": "api_key",
        "label": "Project API key",
        "generateUrl": "https://dashboard.api.video/register",
        "setup": "Sign up or log in via the [api.video dashboard](https://dashboard.api.video/register), open **API Keys**, and copy either your Sandbox or Production project API key as described in the [authentication guide](https://docs.api.video/reference/authentication-guide). This key can be used directly with HTTP Basic auth, or exchanged at `POST /auth/api-key` for a short-lived bearer token.",
        "acquisition": "manual"
      },
      "project_bearer_token": {
        "type": "bearer",
        "label": "Disposable bearer token",
        "setup": "First obtain a [project API key](https://docs.api.video/reference/authentication-guide). Then call `POST /auth/api-key` on `https://sandbox.api.video` or `https://ws.api.video` with JSON body `{\"apiKey\":\"...\"}` as shown in the [advanced authentication docs](https://docs.api.video/reference/api/Advanced-authentication). Use the returned `access_token` until it expires (`3600` seconds), then refresh it with `POST /auth/refresh` using the returned `refresh_token`.",
        "acquisition": "manual"
      },
      "admin_api_key": {
        "type": "api_key",
        "label": "Admin API key",
        "setup": "Request an admin API key from api.video Customer Support as described in the [Admin API overview](https://docs.api.video/reference/admin-api-overview). This key is separate from project API keys and is used as the Basic auth username with an empty password for `https://admin.api.video`.",
        "acquisition": "manual"
      }
