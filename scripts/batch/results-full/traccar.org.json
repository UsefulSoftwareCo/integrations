      "traccar_session": {
        "type": "basic",
        "label": "Traccar session cookie",
        "setup": "Sign in to the Traccar web app or create a session via the API. This is the browser session cookie used by the REST API and the MCP connector. The docs note that session cookies are one authorization option, and the MCP forum thread says you must be logged into Traccar in the same browser session when setting up MCP. Start from the [Traccar API](https://www.traccar.org/traccar-api/) page or your server's login page.",
        "acquisition": "manual"
      },
      "traccar_api_key": {
        "type": "bearer",
        "label": "Traccar account token / access token",
        "setup": "Open the Traccar web app and generate an account token from your user settings, or use the API session token flow described on the [Traccar API](https://www.traccar.org/traccar-api/) page. The docs call this an alternative to email/password login and show it being passed as a `token` query parameter to `/api/session` to create a session. Use this when a bearer-style token is accepted by the API.",
        "acquisition": "manual"
      },
      "traccar_mcp_oauth_client": {
        "type": "oauth2",
        "label": "Traccar OAuth client for MCP",
        "setup": "Enable MCP in Traccar with `<entry key='web.mcp.enable'>true</entry>`, set a public base URL with `<entry key='web.url'>https://your-traccar.example</entry>`, and configure an OpenID client entry such as `<entry key='openid.clients'>client_id:client_secret</entry>`. The forum thread says the MCP endpoint is `{baseUrl}/api/mcp`, and that ChatGPT-style connector setup uses the same client id and secret. This is the credential pair you register in Traccar for the MCP OAuth flow.",
        "acquisition": "manual"
      }
