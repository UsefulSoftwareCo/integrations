    "summary": "dotCMS exposes authenticated REST, GraphQL, and MCP surfaces; all use a dotCMS API token, and the MCP server is launched via `npx -y @dotcms/mcp-server` with `DOTCMS_URL` and `AUTH_TOKEN`.",
    "credentials": {
      "dotcms_api_token": {
        "type": "bearer",
        "label": "dotCMS API token",
        "generateUrl": "https://www.dotcms.com/docs/rest-api-authentication",
        "setup": "Go to the dotCMS admin panel, then **System → Users**. Select the user the integration should run as, open the **API Access Tokens** or **API Access Key** area, and create a new token/key. dotCMS recommends using a separate front-end user with minimum permissions; only administrators can create tokens for users unless the user has the CMS Administrator role. If you need to mint it programmatically, use the REST API token flow described in the docs.",
        "acquisition": "manual"
      },
      "dotcms_mcp_auth_token": {
        "type": "bearer",
        "label": "dotCMS MCP AUTH_TOKEN",
        "generateUrl": "https://www.dotcms.com/docs/mcp-server",
        "setup": "Create a dotCMS API token with the minimum write permissions required for the MCP server, then place that token in the MCP client environment as `AUTH_TOKEN`. The MCP docs say to set both `DOTCMS_URL` and `AUTH_TOKEN` when launching `@dotcms/mcp-server`.",
        "acquisition": "manual"
      }
