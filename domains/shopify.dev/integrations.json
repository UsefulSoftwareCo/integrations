    },
    {
      "authStatus": "required",
      "name": "Storefront API",
      "slug": "storefront-api",
      "type": "graphql",
      "url": "https://shopify.dev/docs/api/storefront/latest"
    },
    {
      "authStatus": "required",
      "command": "shopify",
      "name": "Shopify CLI",
      "slug": "shopify-cli",
      "type": "cli"
    },
    {
      "authStatus": "none",
      "name": "Shopify.dev MCP server",
      "slug": "shopify-dev-mcp-server",
      "type": "mcp"
    }
  ]
}
