    "summary": "Autotrader.co.uk exposes one documented developer integration surface: the Autotrader Connect HTTP API platform, which covers multiple production and beta REST-style APIs and uses short-lived bearer access tokens obtained from Autotrader-issued API credentials.",
    "description": "Autotrader.co.uk is a UK automotive marketplace and retailer platform. Its Connect platform lets partners and retailers integrate vehicle, stock, valuations, search, deals, messaging, and related automotive data/services into their own systems.",
    "credentials": {
      "at_api_credentials": {
        "type": "compound",
        "label": "Autotrader Connect API credentials used to mint short-lived access tokens",
        "generateUrl": "https://www.autotrader.co.uk/partners/retailer/platform/autotrader-connect",
        "setup": "Request direct integration access through the [Autotrader Connect page](https://www.autotrader.co.uk/partners/retailer/platform/autotrader-connect) using the enquiry form or contact Autotrader support. The docs state you use your API credentials to obtain an access token from the Authentication endpoint, but the public pages scraped do not disclose the exact credential fields or self-service issuance flow. Once provisioned by Autotrader, use those credentials against the Authentication endpoint described in the [Integration Fundamentals](https://help.autotrader.co.uk/hc/en-gb/articles/21791620456221-Integration-Fundamentals)."
      },
      "at_access_token": {
        "type": "bearer",
        "label": "Autotrader Connect short-lived access token",
        "generateUrl": "https://help.autotrader.co.uk/hc/en-gb/articles/21791620456221-Integration-Fundamentals",
        "setup": "First obtain Autotrader Connect API credentials from Autotrader via the [Autotrader Connect page](https://www.autotrader.co.uk/partners/retailer/platform/autotrader-connect). Then call the Authentication endpoint described in [Integration Fundamentals](https://help.autotrader.co.uk/hc/en-gb/articles/21791620456221-Integration-Fundamentals) to obtain an access token. The token lasts 15 minutes and should be reused until expiry, then refreshed by requesting a new token."
      }
