    "summary": "nordigen.com exposes one developer integration surface: the Nordigen/Bank Account Data HTTP API for account information, authenticated with Bearer access tokens minted from Nordigen user secrets.",
    "description": "Nordigen provides open banking account-information connectivity for accessing bank account data through PSD2 APIs. Its bank-account-data product and docs are now presented under GoCardless developer properties, while Nordigen-issued user secrets remain the basis for API access.",
    "credentials": {
      "nordigen_user_secrets": {
        "type": "compound",
        "label": "Nordigen user secrets (secret_id + secret_key)",
        "generateUrl": "https://ob.nordigen.com/user-secrets/",
        "setup": "In the Nordigen Open Banking Platform, open the [User Secrets page](https://ob.nordigen.com/user-secrets/) and create a new set of user secrets. Save both the `secret_id` and `secret_key` securely; docs say to store them in your app environment and not commit them to Git. These secrets are then exchanged with the API for tokens.",
        "acquisition": "manual"
      },
      "nordigen_access_token": {
        "type": "bearer",
        "label": "Nordigen access token",
        "setup": "First create user secrets in the [User Secrets page](https://ob.nordigen.com/user-secrets/). Then call the Bank Account Data API token endpoint as described in the [token handling article](https://ob.helpscoutdocs.com/article/132-token-handling-via-api) / [quick start guide](https://developer.gocardless.com/bank-account-data/quick-start-guide/) to exchange `secret_id` and `secret_key` for an access token and refresh token pair. The access token is valid for 24 hours and is sent as a Bearer token in the `Authorization` header.",
        "acquisition": "manual"
      }
    },
