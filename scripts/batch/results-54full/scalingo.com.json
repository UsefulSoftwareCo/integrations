    "summary": "Scalingo exposes two documented REST APIs—the main Scalingo API v1 and the Database API v1—plus a documented `scalingo` CLI; both APIs use short-lived Bearer tokens obtained by exchanging a long-lived Scalingo API token.",
    "description": "Scalingo is a cloud application platform (PaaS) for deploying and operating applications and managed databases. Its public developer docs cover platform management APIs, database management APIs, and tooling for deploying and managing apps.",
    "credentials": {
      "scalingo_api_token": {
        "type": "api_key",
        "label": "Scalingo API token",
        "generateUrl": "https://dashboard.scalingo.com/account/tokens",
        "setup": "Create a token from the Scalingo dashboard at [Create your API Token](https://dashboard.scalingo.com/account/tokens). The docs also describe creating one via `POST https://auth.scalingo.com/v1/tokens` using your account credentials, but the dashboard page is the easiest path. This long-lived token must then be exchanged for a short-lived Bearer token before calling the APIs.",
        "acquisition": "manual"
      },
      "scalingo_bearer_token": {
        "type": "bearer",
        "label": "Scalingo Bearer token",
        "generateUrl": "https://auth.scalingo.com/v1/tokens/exchange",
        "setup": "First create a long-lived API token from [the dashboard token page](https://dashboard.scalingo.com/account/tokens). Then exchange it for a Bearer token by calling `POST https://auth.scalingo.com/v1/tokens/exchange` with HTTP Basic auth username empty and password set to the API token, as documented on [Tokens](https://developers.scalingo.com/tokens). The returned Bearer token is valid for 1 hour and is what Scalingo APIs accept in the `Authorization: Bearer` header.",
        "acquisition": "manual"
      }
    },
