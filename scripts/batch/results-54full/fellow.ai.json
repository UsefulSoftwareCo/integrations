      "fellow_api_key": {
        "type": "api_key",
        "label": "Fellow Developer API key",
        "generateUrl": "https://help.fellow.ai/en/articles/11817206-developer-api",
        "setup": "Have a workspace admin enable the Developer API in **Workspace Settings → Security**. Then log into Fellow, open **User Settings → Developer tools**, click the button to create a new key, give it a descriptive name, and copy the value when shown; it is only displayed once. See [Developer API](https://help.fellow.ai/en/articles/11817206-developer-api) and [Authentication](https://developers.fellow.ai/reference/authentication-1)."
      },
      "fellow_super_admin_key": {
        "type": "api_key",
        "label": "Fellow Super Admin API key",
        "generateUrl": "https://developers.fellow.ai/reference/super-admin",
        "setup": "Use an Enterprise plan workspace with a designated Super Admin. To get Super Admin access, contact your Fellow CSM or email [support@fellow.co](mailto:support@fellow.co). Super Admin endpoints use the same Developer API key mechanism but with privileged access enabled for the issued key. See [Super Admin](https://developers.fellow.ai/reference/super-admin) and [Developer API](https://help.fellow.ai/en/articles/11817206-developer-api)."
      },
      "fellow_mcp_oauth": {
        "type": "oauth2",
        "label": "Fellow MCP connection authorization",
        "generateUrl": "https://help.fellow.ai/en/articles/12622641-fellow-s-mcp-server",
        "setup": "Have a workspace admin enable **Workspace Settings → Security → Allow users to create MCP connections**. Then connect an MCP client such as Claude, ChatGPT, Cursor, or Copilot to `https://fellow.app/mcp` and sign into Fellow when redirected to authorize the connection. ChatGPT docs explicitly say to leave OAuth client ID and secret blank and complete authorization on Fellow’s side. See [Fellow's MCP Server](https://help.fellow.ai/en/articles/12622641-fellow-s-mcp-server) and [MCP Server](https://developers.fellow.ai/reference/mcp-server)."
      }
    },
