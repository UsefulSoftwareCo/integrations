{
  "domain": "zitadel.com",
  "summary": "ZITADEL exposes public OIDC and SAML endpoints plus authenticated HTTP APIs for Management, Project, and self-hosted System access; no GraphQL, MCP, or CLI surface was confirmed from the docs reviewed.",
  "surfaces": [
    {
      "authStatus": "required",
      "name": "ZITADEL Management API",
      "slug": "zitadel-management-api",
      "type": "http"
    },
    {
      "authStatus": "required",
      "name": "ZITADEL Project API",
      "slug": "zitadel-project-api",
      "type": "http"
    },
    {
      "authStatus": "none",
      "name": "ZITADEL OpenID Connect endpoints",
      "slug": "zitadel-openid-connect-endpoints",
      "type": "http",
      "url": "${CUSTOM_DOMAIN}"
    },
    {
      "authStatus": "required",
      "name": "ZITADEL System API",
      "slug": "zitadel-system-api",
      "type": "http",
      "url": "${CUSTOM_DOMAIN}/system/v1"
    }
  ]
