        "generateUrl": "https://mockoon.com/account/access-tokens/",
        "setup": "In your Mockoon Cloud account, open the [access tokens page](https://mockoon.com/account/access-tokens/) and create a token. Choose the needed permissions; current docs list `environment:read` for self-hosting cloud environments with the CLI. This feature requires a Team or higher plan per the [access tokens docs](https://mockoon.com/cloud/docs/access-tokens/).",
        "acquisition": "manual"
      },
      "admin_api_token": {
        "type": "bearer",
        "label": "Mockoon admin API bearer token",
        "setup": "For the desktop app, start Mockoon and read the generated admin API token from each mock API's Settings tab, or set `MOCKOON_ADMIN_API_TOKEN` before launch to override it for all mocks. For the CLI, pass your own token with `--admin-api-token` or the `MOCKOON_ADMIN_API_TOKEN` environment variable, or let Mockoon generate one at startup and read it from the logs. See the [Admin API overview](https://mockoon.com/docs/latest/admin-api/overview/).",
        "acquisition": "manual"
      },
      "cloud_instance_api_key": {
        "type": "bearer",
        "label": "Mockoon Cloud deployed instance API key",
        "setup": "Deploy an environment from the desktop application using Mockoon Cloud. In the deployment management dialog, Mockoon shows the instance URL and the API key. For private cloud instances, include this key in the request `Authorization` header to access the environment; for public instances, the same key is still required for the environment's admin API. See [Cloud API mock deployments](https://mockoon.com/cloud/docs/api-mock-cloud-deployments/).",
        "acquisition": "manual"
      }
    },
