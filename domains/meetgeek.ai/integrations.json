    },
    {
      "authStatus": "required",
      "name": "MeetGeek Cloud MCP",
      "slug": "meetgeek-cloud-mcp",
      "type": "mcp",
      "url": "https://mcp.meetgeek.ai/mcp"
    }
  ]
