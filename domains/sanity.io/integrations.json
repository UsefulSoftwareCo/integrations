{
  "domain": "sanity.io",
  "summary": "Sanity exposes one authenticated HTTP API, one authenticated GraphQL API, a hosted MCP server, and the Sanity CLI; auth is via Sanity account login/OAuth and project API tokens.",
  "surfaces": [
    {
      "authStatus": "required",
      "name": "Sanity HTTP API",
      "slug": "sanity-http-api",
      "type": "http",
      "url": "https://<projectId>.api.sanity.io/<version>/"
    },
    {
      "authStatus": "required",
      "name": "Sanity GraphQL API",
      "slug": "sanity-graphql-api",
      "spec": "introspection",
      "type": "graphql",
      "url": "https://<projectId>.api.sanity.io/<version>/graphql/<dataset>/<apiId>"
    },
    {
      "authStatus": "required",
      "name": "Sanity MCP server",
      "slug": "sanity-mcp-server",
      "type": "mcp",
      "url": "https://mcp.sanity.io"
    },
    {
      "authStatus": "required",
      "command": "sanity",
      "name": "Sanity CLI",
      "slug": "sanity-cli",
      "type": "cli"
    }
  ]
}
