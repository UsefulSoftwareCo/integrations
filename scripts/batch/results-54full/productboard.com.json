    "summary": "Productboard exposes a REST API v2 at `https://api.productboard.com` authenticated by bearer API token, OAuth 2.0 authorization-code, or server-to-server JWT-bearer tokens, a SCIM API at `https://api.productboard.com/scim/v2` with auth not confirmed from the recorded docs, and a beta MCP server at `https://mcp.productboard.com` authenticated via OAuth Dynamic Client Registration plus PKCE.",
    "credentials": {
      "pb_api_token": {
        "type": "api_key",
        "label": "Productboard personal access token",
        "generateUrl": "https://developer.productboard.com/reference/api-token",
        "setup": "In Productboard's developer docs, Productboard lists **API Token (PAT)** as a supported authentication method for REST API v2. Use the API token instructions in [Authentication](https://developer.productboard.com/reference/authentication) and [API Token Authentication](https://developer.productboard.com/reference/api-token) to generate a token in your Productboard workspace/account, then send it on REST API requests."
      },
      "pb_oauth_app": {
        "type": "oauth2",
        "label": "Productboard OAuth 2.0 app (authorization code)",
        "generateUrl": "https://developer.productboard.com/reference/oauth-authorization-code",
        "setup": "For a server-side integration acting on Productboard users' behalf, create/configure an OAuth app per the [OAuth 2.0 (Authorization Code)](https://developer.productboard.com/reference/oauth-authorization-code) guide, then use Productboard's authorization-code flow to obtain bearer tokens for the REST API."
      },
      "pb_jwt_app": {
        "type": "oauth2_cc",
        "label": "Productboard server-to-server OAuth app (JWT bearer)",
        "generateUrl": "https://developer.productboard.com/reference/oauth-server-to-server",
        "setup": "For backend automation without a user present, configure a server-to-server integration following [OAuth Server-to-Server (JWT)](https://developer.productboard.com/reference/oauth-server-to-server). Productboard documents this as an OAuth 2.0 JWT bearer flow that returns bearer access tokens for API calls."
      },
      "pb_mcp_public_client": {
        "type": "oauth2",
        "label": "Productboard MCP OAuth public client registration",
        "generateUrl": "https://app.productboard.com/oauth2/register",
        "setup": "If you're building your own MCP client, register it dynamically with Productboard by `POST`ing to `https://app.productboard.com/oauth2/register` as documented in [OAuth for MCP Clients (DCR)](https://developer.productboard.com/reference/oauth-public-client). Persist the returned `client_id`; Productboard issues no client secret for these public clients, and sign-in uses the authorization code flow with PKCE. If you're just connecting an existing agent such as Claude Code or Cursor, follow [Connecting your agent](https://developer.productboard.com/reference/mcp-install) instead and let the client handle registration/sign-in."
      }
    },
