    "summary": "Postmark exposes two authenticated HTTP APIs (server-level and account-level), an official CLI, and references an MCP server; it also supports SMTP for sending mail.",
    "description": "Postmark is a transactional email service for sending, receiving, and tracking application email. It provides server-level and account-level management features for messages, templates, domains, sender signatures, and delivery data.",
    "credentials": {
      "server_api_token": {
        "type": "api_key",
        "label": "Server API token",
        "generateUrl": "https://account.postmarkapp.com",
        "setup": "Sign in to your Postmark account, open the relevant server, then go to the server **API Tokens** tab to copy a Server API token. Postmark’s docs state this token is found on the server credentials/API Tokens page and is used for server-level API requests; a server can have up to 3 API tokens. See [API overview](https://postmarkapp.com/developer/api/overview), [API Explorer](https://postmarkapp.com/api-explorer), and [token explanation](https://postmarkapp.com/support/article/1008-what-are-the-account-and-server-api-tokens).",
        "acquisition": "manual"
      },
      "account_api_token": {
        "type": "api_key",
        "label": "Account API token",
        "generateUrl": "https://account.postmarkapp.com/account/edit",
        "setup": "Sign in to Postmark, open the account-level **API Tokens** page in the **Account** section, and copy the Account API token. Postmark’s docs say this token is required for account-level actions such as creating servers and managing sender signatures or domains. See [API Explorer](https://postmarkapp.com/api-explorer) and [token explanation](https://postmarkapp.com/support/article/1008-what-are-the-account-and-server-api-tokens).",
        "acquisition": "manual"
      },
      "smtp_token_pair": {
        "type": "compound",
        "label": "SMTP token pair (Access Key + Secret Key)",
        "generateUrl": "https://account.postmarkapp.com",
        "setup": "Sign in to Postmark, open an outbound message stream, then use the stream **Settings** tab to generate an SMTP Token. Postmark says SMTP Tokens are stream-specific and consist of two values that must be used together: the **Access Key** as the SMTP username and the **Secret Key** as the SMTP password. If the secret is lost, generate a new token. See [token explanation](https://postmarkapp.com/support/article/1008-what-are-the-account-and-server-api-tokens).",
        "acquisition": "manual"
      }
    },
